<odoo>
    <record id="payment_provider_mpesa" model="payment.provider">
        <field name="name">M-Pesa</field>
        <field name="code">mpesa</field>
        <field name="state">test</field>
        <field name="mpesa_base_url">https://sandbox.safaricom.co.ke</field>
        <field name="is_published">True</field>
    </record>

    <record id="mpesa_account_payment_method" model="account.payment.method">
        <field name="name">M-Pesa</field>
        <field name="code">mpesa</field>
        <field name="payment_type">inbound</field>
    </record>

    <record id="mpesa_account_payment_method_line" model="account.payment.method.line">
        <field name="name">M-Pesa</field>
        <field name="code">mpesa</field>
        <field name="payment_provider_id" ref="payment_provider_mpesa"/>
        <field name="payment_method_id" ref="mpesa_account_payment_method"/>
    </record>
</odoo>
