<template id="mpesa_checkout_fields" inherit_id="payment.payment_form">
    <xpath expr="//div[@id='payment_form']" position="before">
        <t t-if="provider_code == 'mpesa'">
            <div class="form-group mt-3">
                <label for="mpesa_phone_input">M-Pesa Phone Number</label>
                <input type="tel" id="mpesa_phone_input" name="mpesa_phone_input"
                    class="form-control" placeholder="e.g. 0712345678" required="true"/>
            </div>
        </t>
    </xpath>
</template>
