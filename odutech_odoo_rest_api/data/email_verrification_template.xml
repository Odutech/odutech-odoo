<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_user_email_registration_verification" model="mail.template">
        <field name="name">User Registration: Account Verification</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="subject">Verify Your Account - {{ object.company_id.name }}</field>
        <field name="email_from">{{ (object.company_id.email_formatted or object.company_id.email or '') }}</field>
        <field name="email_to">{{ object.email_formatted }}</field>
        <field name="lang">{{ object.lang }}</field>
        <field name="body_html" type="html">
            <table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 24px; background-color: #FFFFFF; border: 1px solid #E7E7E7; border-collapse:separate;">
                            <tr>
                                <td align="left" style="min-width: 590px;">
                                    <p style="margin: 0px 0px 10px 0px; font-size: 16px; font-weight: bold;">
                                        Hello <t t-out="object.name"/>,
                                    </p>
                                    <p style="margin: 0px 0px 24px 0px; font-size: 14px; line-height: 20px;">
                                        Thank you for registering an account with <t t-out="object.company_id.name"/>. To complete your setup and ensure secure access to your dashboard, please verify your email address by clicking the button below:
                                    </p>
                                    <div style="margin: 32px 0px 32px 0px; text-align: center;">
                                        <a t-att-href="ctx.get('verification_url')" style="padding: 12px 24px; color: #FFFFFF; text-decoration: none; background-color: #714B67; border-radius: 5px; font-size: 14px; font-weight: bold;">
                                            Verify Email Address
                                        </a>
                                    </div>
                                    <p style="margin: 0px 0px 10px 0px; font-size: 12px; color: #666666; line-height: 16px;">
                                        If the button above does not work, copy and paste the following link into your web browser:
                                        <br/>
                                        <t t-out="ctx.get('verification_url')"/>
                                    </p>
                                    <hr style="width: 100%; border-top: 1px solid #E7E7E7; margin: 32px 0px 24px 0px;"/>
                                    <p style="margin: 0px; font-size: 13px; line-height: 18px; color: #777777;">
                                        Best regards,
                                        <br/>
                                        The Odutech Support Team
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </field>
    </record>

        <record id="email_template_user_registration_verification" model="mail.template">
        <field name="name">User Registration: Account Verified</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="subject">Welcome! Your Email is Verified Successfully</field>
        <field name="email_from">{{ object.company_id.email or object.env.user.email_formatted }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="lang">{{ object.lang }}</field>
        <field name="body_html" type="html">
            <table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 24px; background-color: #FFFFFF; border: 1px solid #E7E7E7; border-collapse:separate;">
                            <tr>
                                <td align="left" style="min-width: 590px;">
                                    <p style="margin: 0px 0px 10px 0px; font-size: 16px; font-weight: bold;">
                                        Hello <t t-out="object.name"/>,
                                    </p>
                                    <p style="margin: 0px 0px 24px 0px; font-size: 14px; line-height: 20px;">
                                        Thank you for registering! Your email address has been successfully verified, and your multi-tenant workspace is ready for use.
                                    </p>

                                    <div style="background-color: #F8F9FA; border-left: 4px solid #714B67; padding: 16px; margin: 0px 0px 24px 0px; font-size: 13px; line-height: 22px;">
                                        <strong>Company Tenant Name:</strong> <t t-out="object.company_id.name"/><br/>
                                        <strong>Unique Subscription Code:</strong> <span style="font-size: 14px; font-weight: bold; color: #714B67;"><t t-out="object.company_id.subscription_code"/></span><br/>
                                        <strong>Authorization Tier:</strong> <t t-out="object.company_id.api_authorization_tier"/><br/>

                                        <t t-if="object.company_id.api_authorization_tier == 'trial'">
                                            <strong>Trial Expiration Date:</strong> <t t-out="object.company_id.api_tier_expiration_date"/> (30 days of free access)<br/>
                                        </t>
                                    </div>

                                    <p style="margin: 0px 0px 24px 0px; font-size: 13px; line-height: 20px; color: #666666;">
                                        Please keep your subscription code secure, as it serves as your primary authorization reference for managing your tenant's API environment operations.
                                    </p>

                                    <hr style="width: 100%; border-top: 1px solid #E7E7E7; margin: 32px 0px 24px 0px;"/>
                                    <p style="margin: 0px; font-size: 13px; line-height: 18px; color: #777777;">
                                        Best regards,
                                        <br/>
                                        The Operations Team
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </field>
    </record>
    </data>
</odoo>