<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Insurance Aging Alerts -->
        <record id="cron_insurance_aging_alert" model="ir.cron">
            <field name="name">EYEKEI: Insurance Aging Alerts</field>
            <field name="model_id" ref="model_eyekei_insurance_claim"/>
            <field name="state">code</field>
            <field name="code">
                model.search([
                    ('state', 'in', ['submitted', 'partial_approved']),
                    ('submission_date', '&lt;', (datetime.date.today() - datetime.timedelta(days=30)).isoformat())
                ]).write({'state': 'aging_alert'})
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <!-- <field name="numbercall">-1</field> -->
        </record>
        
