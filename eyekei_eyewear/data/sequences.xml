<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Patient ID -->
        <record id="seq_eyekei_patient" model="ir.sequence">
            <field name="name">EYEKEI Patient</field>
            <field name="code">eyekei.patient</field>
            <field name="prefix">EYE-</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Visit ID -->
        <record id="seq_eyekei_visit" model="ir.sequence">
            <field name="name">EYEKEI Visit</field>
            <field name="code">eyekei.visit</field>
            <field name="prefix">VIS-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Prescription ID -->
        <record id="seq_eyekei_prescription" model="ir.sequence">
            <field name="name">EYEKEI Prescription</field>
            <field name="code">eyekei.prescription</field>
            <field name="prefix">RX-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Lab Job ID -->
        <record id="seq_eyekei_lab_job" model="ir.sequence">
            <field name="name">EYEKEI Lab Job</field>
            <field name="code">eyekei.lab.job</field>
            <field name="prefix">LAB-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Insurance Claim -->
        <record id="seq_eyekei_claim" model="ir.sequence">
            <field name="name">EYEKEI Insurance Claim</field>
            <field name="code">eyekei.claim</field>
            <field name="prefix">CLM-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Submission Batch -->
        <record id="seq_eyekei_submission_batch" model="ir.sequence">
            <field name="name">EYEKEI Submission Batch</field>
            <field name="code">eyekei.submission.batch</field>
            <field name="prefix">INS-SUB-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Submission Serial -->
        <record id="seq_eyekei_submission_serial" model="ir.sequence">
            <field name="name">EYEKEI Submission Serial</field>
            <field name="code">eyekei.submission.serial</field>
            <field name="prefix">INS-SUB-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Payment Entry -->
        <record id="seq_eyekei_payment" model="ir.sequence">
            <field name="name">EYEKEI Payment Entry</field>
            <field name="code">eyekei.payment.entry</field>
            <field name="prefix">PAY-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Frame ID -->
        <record id="seq_eyekei_frame" model="ir.sequence">
            <field name="name">EYEKEI Frame</field>
            <field name="code">eyekei.frame</field>
            <field name="prefix">FRM-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Lens ID -->
        <record id="seq_eyekei_lens" model="ir.sequence">
            <field name="name">EYEKEI Lens</field>
            <field name="code">eyekei.lens</field>
            <field name="prefix">LNS-</field>
            <field name="padding">6</field>
        </record>
        
        <!-- Remake ID -->
        <record id="seq_eyekei_remake" model="ir.sequence">
            <field name="name">EYEKEI Remake</field>
            <field name="code">eyekei.remake</field>
            <field name="prefix">RMK-</field>
            <field name="padding">6</field>
        </record>

        <!-- Stock Adjust Audit ID -->
        <record id="seq_eyekei_stock_audit" model="ir.sequence">
            <field name="name">EYEKEI Stock Audit</field>
            <field name="code">eyekei.stock.audit</field>
            <field name="prefix">AUD-</field>
            <field name="padding">6</field>
        </record>

        <record id="seq_material_request" model="ir.sequence">
            <field name="name">Material Request Sequence</field>
            <field name="code">material.request</field>
            <field name="prefix">OPTEX/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>