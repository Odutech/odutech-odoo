<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Email Template for Insurance Claim Submission -->
    <record id="email_template_insurance_claim" model="mail.template">
        <field name="name">Insurance Claim: Send to Insurance</field>
        <field name="model_id" ref="model_eyekei_insurance_claim" />
        <field name="subject">Insurance Claim Submission: {{ object.name }}</field>
        <field name="email_from">{{ (object.env.user.email_formatted or object.env.company.email or '') }}</field>
        <field name="email_to">{{ object.insurance_company_id.email }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Dear
                    <t t-out="object.insurance_company_id.contact_person or 'Sir/Madam'" />,<br /><br />

                    Please find attached the insurance claim <strong>
                        <t t-out="object.name" /></strong> for your review and processing.<br /><br />

                    <strong>Claim Details:</strong><br />
                    - Patient:
                    <t t-out="object.patient_id.name" /><br />
                    - Member Number:
                    <t t-out="object.member_number or 'N/A'" /><br />
                    - Scheme:
                    <t t-out="object.scheme_id.name or 'N/A'" /><br />
                    - Billed Amount:
                    <t t-out="object.billed_amount"
                        t-options="{'widget': 'monetary', 'display_currency': object.currency_id}" /><br />
                    - Invoice Number:
                    <t t-out="object.invoice_id.name or 'N/A'" /><br />
                    <t t-if="object.etims_number">
                        <!-- - eTIMS Number: <t t-out="object.etims_number"/><br/> -->
                    </t>
                    <br />

                    Kindly process this claim at your earliest convenience.<br /><br />

                    Regards,<br />
                    <t t-out="object.env.user.name" /><br />
                    <t t-out="object.env.company.name" /><br />
                    <t t-out="object.env.company.phone or ''" />
                </p>
            </div>
        </field>
        <field name="auto_delete" eval="True" />
    </record>
</odoo>