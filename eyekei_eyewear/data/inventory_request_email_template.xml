<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_material_request_approval_notification" model="mail.template">
            <field name="name">Material Request: Send to Main Hub</field>
            <field name="model_id" ref="eyekei_eyewear.model_material_request"/>
            <field name="subject">Urgent Inventory Transfer Request: {{ object.sequence_number or 'Draft' }}</field>
            <field name="email_to">{{ object.origin_warehouse_id.partner_id.email }}</field>
            <field name="email_from">{{ object.create_uid.email or object.company_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p style="margin: 0px; padding: 0px;">
                        Hello Fulfillment Team,<br/><br/>
                        A new internal inventory transfer request has been generated and requires staging at your hub.
                        <br/><br/>
                        <strong>Request Reference:</strong> <t t-out="object.sequence_number"/><br/>
                        <strong>Destination Warehouse:</strong> <t t-out="object.warehouse_id.name"/><br/>
                        <strong>Expected Delivery Date:</strong> <t t-out="object.date_expected"/>
                        <br/><br/>
                        <strong>Materials Requested:</strong>
                    </p>

                    <table style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f2f2f2; text-align: left;">
                                <th style="padding: 8px; border: 1px solid #dddddd;">Product</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.request_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 8px; border: 1px solid #dddddd;"><t t-out="line.product_id.display_name"/></td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right; font-weight: bold;"><t t-out="line.qty_requested"/> Units</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin: 30px 0px; text-align: center;">
                        <a t-att-href="'/web#id=%s&amp;model=material.request&amp;view_type=form' % object.id"
                           style="background-color: #875A7B; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-weight: bold;">
                            View Material Request
                        </a>
                    </div>

                    <p style="margin-top: 25px; margin-bottom: 0px;">
                        Best regards,<br/>
                        <strong><t t-out="object.location_id.display_name or object.warehouse_id.name"/></strong>
                    </p>

                    <hr style="margin-top: 30px; border: none; border-top: 1px solid #eeeeee;"/>
                    <p style="font-size: 11px; color: #777777; margin: 0px;">
                        This is an automated operational notification sent on behalf of the requesting branch center.
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_material_request_approved_notification" model="mail.template">
            <field name="name">Material Request: Approved Notification</field>
            <field name="model_id" ref="eyekei_eyewear.model_material_request"/>
            <field name="subject">Approved: Inventory Transfer Request {{ object.sequence_number or 'Draft' }}</field>
            <field name="email_to">{{ object.create_uid.email }}</field>
            <field name="email_from">{{ object.company_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p style="margin: 0px; padding: 0px;">
                        Hello <t t-out="object.create_uid.name"/>,<br/><br/>
                        Great news! Your internal inventory transfer request has been **approved** and has been routed to the fulfillment hub for staging.
                        <br/><br/>
                        <strong>Request Reference:</strong> <t t-out="object.sequence_number"/><br/>
                        <strong>Destination Warehouse:</strong> <t t-out="object.warehouse_id.name"/><br/>
                        <strong>Expected Delivery Date:</strong> <t t-out="object.date_expected"/>
                        <br/><br/>
                        <strong>Approved Materials:</strong>
                    </p>

                    <table style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f2f2f2; text-align: left;">
                                <th style="padding: 8px; border: 1px solid #dddddd;">Product</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.request_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 8px; border: 1px solid #dddddd;"><t t-out="line.product_id.display_name"/></td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right; font-weight: bold;"><t t-out="line.qty_requested"/> Units</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin: 30px 0px; text-align: center;">
                        <a t-att-href="'/web#id=%s&amp;model=material.request&amp;view_type=form' % object.id"
                           style="background-color: #28a745; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-weight: bold;">
                            View Approved Request
                        </a>
                    </div>

                    <p style="margin-top: 25px; margin-bottom: 0px;">
                        Best regards,<br/>
                        <strong>Inventory Management System</strong>
                    </p>

                    <hr style="margin-top: 30px; border: none; border-top: 1px solid #eeeeee;"/>
                    <p style="font-size: 11px; color: #777777; margin: 0px;">
                        This is an automated operational status update regarding your submitted request.
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_material_request_rejected_notification" model="mail.template">
            <field name="name">Material Request: Rejected Notification</field>
            <field name="model_id" ref="eyekei_eyewear.model_material_request"/>
            <field name="subject">Rejected: Inventory Transfer Request {{ object.sequence_number or 'Draft' }}</field>
            <field name="email_to">{{ object.create_uid.email }}</field>
            <field name="email_from">{{ object.company_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p style="margin: 0px; padding: 0px;">
                        Hello <t t-out="object.create_uid.name"/>,<br/><br/>
                        We regret to inform you that your internal inventory transfer request has been **rejected** and will not be processed.
                        <br/><br/>
                        <strong>Request Reference:</strong> <t t-out="object.sequence_number"/><br/>
                        <strong>Destination Warehouse:</strong> <t t-out="object.warehouse_id.name"/><br/>
                        <strong>Expected Delivery Date:</strong> <t t-out="object.date_expected"/>
                    </p>

                    <!-- Rejection Reason Callout Box -->
                    <div style="margin: 20px 0px; padding: 15px; background-color: #fdf2f2; border-left: 4px solid #dc3545; color: #b52a37;">
                        <strong style="display: block; margin-bottom: 5px;">Reason for Rejection:</strong>
                        <t t-out="object.rejection_reason or 'No reason specified by the reviewer.'"/>
                    </div>

                    <p style="margin: 0px; padding: 0px;">
                        <strong>Rejected Materials:</strong>
                    </p>

                    <table style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f2f2f2; text-align: left;">
                                <th style="padding: 8px; border: 1px solid #dddddd;">Product</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.request_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 8px; border: 1px solid #dddddd;"><t t-out="line.product_id.display_name"/></td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right; font-weight: bold;"><t t-out="line.qty_requested"/> Units</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin: 30px 0px; text-align: center;">
                        <a t-att-href="'/web#id=%s&amp;model=material.request&amp;view_type=form' % object.id"
                           style="background-color: #dc3545; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-weight: bold;">
                            View Request Details
                        </a>
                    </div>

                    <p style="margin-top: 25px; margin-bottom: 0px;">
                        Best regards,<br/>
                        <strong>Inventory Management System</strong>
                    </p>

                    <hr style="margin-top: 30px; border: none; border-top: 1px solid #eeeeee;"/>
                    <p style="font-size: 11px; color: #777777; margin: 0px;">
                        This is an automated operational status update regarding your submitted request. If you need to revise and resubmit, please click the link above.
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_material_request_dispatched_notification" model="mail.template">
            <field name="name">Material Request: Dispatched Notification</field>
            <field name="model_id" ref="eyekei_eyewear.model_material_request"/>
            <field name="subject">Dispatched: Inventory Transfer Request {{ object.sequence_number or 'Draft' }}</field>
            <field name="email_to">{{ object.create_uid.email }}</field>
            <field name="email_from">{{ object.company_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p style="margin: 0px; padding: 0px;">
                        Hello <t t-out="object.create_uid.name"/>,<br/><br/>
                        Your internal inventory transfer request has been **dispatched** from the hub and is now en route to its destination.
                        <br/><br/>
                        <strong>Request Reference:</strong> <t t-out="object.sequence_number"/><br/>
                        <strong>Destination Warehouse:</strong> <t t-out="object.warehouse_id.name"/><br/>
                        <strong>Expected Delivery Date:</strong> <t t-out="object.date_expected"/>
                    </p>

                    <!-- Logistics / Courier Information Box -->
                    <div style="margin: 20px 0px; padding: 15px; background-color: #f4f7f9; border-left: 4px solid #007bff; color: #1e4e79;">
                        <strong style="display: block; margin-bottom: 5px;">Shipping Details:</strong>
                        <strong>Courier / Driver:</strong> <t t-out="object.courier_name or 'Internal Logistics Team'"/>
                    </div>

                    <p style="margin: 0px; padding: 0px;">
                        <strong>Items in Transit:</strong>
                    </p>

                    <table style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f2f2f2; text-align: left;">
                                <th style="padding: 8px; border: 1px solid #dddddd;">Product</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.request_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 8px; border: 1px solid #dddddd;"><t t-out="line.product_id.display_name"/></td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right; font-weight: bold;"><t t-out="line.qty_requested"/> Units</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin: 30px 0px; text-align: center;">
                        <a t-att-href="'/web#id=%s&amp;model=material.request&amp;view_type=form' % object.id"
                           style="background-color: #007bff; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-weight: bold;">
                            Track Transfer Details
                        </a>
                    </div>

                    <p style="margin-top: 25px; margin-bottom: 0px;">
                        Best regards,<br/>
                        <strong>Inventory Management System</strong>
                    </p>

                    <hr style="margin-top: 30px; border: none; border-top: 1px solid #eeeeee;"/>
                    <p style="font-size: 11px; color: #777777; margin: 0px;">
                        This is an automated logistics notification. Please ensure arrangements are made at the receiving location to accept the delivery.
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_material_request_received_perfect" model="mail.template">
            <field name="name">Material Request: Received Perfect Notification</field>
            <field name="model_id" ref="eyekei_eyewear.model_material_request"/>
            <field name="subject">Delivery Confirmed: Inventory Transfer {{ object.sequence_number or 'Draft' }} Received in Full</field>
            <field name="email_to">{{ object.create_uid.email }}</field>
            <field name="email_from">{{ object.company_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p style="margin: 0px; padding: 0px;">
                        Hello <t t-out="object.create_uid.name"/>,<br/><br/>
                        We are pleased to inform you that your internal inventory transfer request has been **successfully received**. The fulfillment verification process is complete.
                        <br/><br/>
                        <strong>Request Reference:</strong> <t t-out="object.sequence_number"/><br/>
                        <strong>Receiving Warehouse:</strong> <t t-out="object.warehouse_id.name"/><br/>
                        <strong>Completion Date:</strong> <t t-out="object.write_date" t-options='{"widget": "date"}'/>
                    </p>

                    <!-- Verification Status Callout Box -->
                    <div style="margin: 20px 0px; padding: 15px; background-color: #f3faf4; border-left: 4px solid #28a745; color: #1e5c2b;">
                        <strong style="display: block; margin-bottom: 5px;">Quality Assurance Status:</strong>
                        All items have been verified. The received quantities **perfectly match** your requested order with zero discrepancies.
                    </div>

                    <p style="margin: 0px; padding: 0px;">
                        <strong>Verified Items:</strong>
                    </p>

                    <table style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f2f2f2; text-align: left;">
                                <th style="padding: 8px; border: 1px solid #dddddd;">Product</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Requested</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Received</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.request_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 8px; border: 1px solid #dddddd;"><t t-out="line.product_id.display_name"/></td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right;"><t t-out="line.qty_requested"/> Units</td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right; font-weight: bold; color: #28a745;"><t t-out="line.qty_requested"/> Units</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin: 30px 0px; text-align: center;">
                        <a t-att-href="'/web#id=%s&amp;model=material.request&amp;view_type=form' % object.id"
                           style="background-color: #28a745; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-weight: bold;">
                            View Completed Request
                        </a>
                    </div>

                    <p style="margin-top: 25px; margin-bottom: 0px;">
                        Best regards,<br/>
                        <strong>Inventory Management System</strong>
                    </p>

                    <hr style="margin-top: 30px; border: none; border-top: 1px solid #eeeeee;"/>
                    <p style="font-size: 11px; color: #777777; margin: 0px;">
                        This is an automated system confirmation. No further operational actions are required for this transaction.
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_material_request_received_discrepancy" model="mail.template">
            <field name="name">Material Request: Received with Discrepancy</field>
            <field name="model_id" ref="eyekei_eyewear.model_material_request"/>
            <field name="subject">Discrepancy Alert: Inventory Transfer {{ object.sequence_number or 'Draft' }} Received with Mismatches</field>
            <field name="email_to">{{ object.create_uid.email }}</field>
            <field name="email_from">{{ object.company_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p style="margin: 0px; padding: 0px;">
                        Hello <t t-out="object.create_uid.name"/>,<br/><br/>
                        Your internal inventory transfer request has arrived at its destination, but a **quantity discrepancy** was flagged during the verification process.
                        <br/><br/>
                        <strong>Request Reference:</strong> <t t-out="object.sequence_number"/><br/>
                        <strong>Receiving Warehouse:</strong> <t t-out="object.warehouse_id.name"/><br/>
                        <strong>Verification Date:</strong> <t t-out="object.write_date" t-options='{"widget": "date"}'/>
                    </p>

                    <!-- Discrepancy Warning Callout Box -->
                    <div style="margin: 20px 0px; padding: 15px; background-color: #fff9e6; border-left: 4px solid #ff9800; color: #663c00;">
                        <strong style="display: block; margin-bottom: 5px;">Attention Required:</strong>
                        The physical count at arrival does not match your original order data. Please check the detailed variance breakdown below.
                    </div>

                    <p style="margin: 0px; padding: 0px;">
                        <strong>Quantities Breakdown:</strong>
                    </p>

                    <table style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f2f2f2; text-align: left;">
                                <th style="padding: 8px; border: 1px solid #dddddd;">Product</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Requested</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Physically Received</th>
                                <th style="padding: 8px; border: 1px solid #dddddd; text-align: right;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.request_line_ids" t-as="line">
                                <tr>
                                    <td style="padding: 8px; border: 1px solid #dddddd;"><t t-out="line.product_id.display_name"/></td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right;"><t t-out="line.qty_requested"/> Units</td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right; font-weight: bold;"><t t-out="line.qty_received"/> Units</td>
                                    <td style="padding: 8px; border: 1px solid #dddddd; text-align: right;">
                                        <span t-if="line.qty_requested == line.qty_received" style="color: #28a745; font-weight: bold;">✔ Match</span>
                                        <span t-if="line.qty_requested != line.qty_received" style="color: #dc3545; font-weight: bold;">⚠ Mismatch</span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin: 30px 0px; text-align: center;">
                        <a t-att-href="'/web#id=%s&amp;model=material.request&amp;view_type=form' % object.id"
                           style="background-color: #ff9800; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-weight: bold;">
                            Review Inventory Discrepancy
                        </a>
                    </div>

                    <p style="margin-top: 25px; margin-bottom: 0px;">
                        Best regards,<br/>
                        <strong>Inventory Management System</strong>
                    </p>

                    <hr style="margin-top: 30px; border: none; border-top: 1px solid #eeeeee;"/>
                    <p style="font-size: 11px; color: #777777; margin: 0px;">
                        This is an automated operational system alert. Your inventory control team may contact you shortly to reconcile this transfer error.
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>