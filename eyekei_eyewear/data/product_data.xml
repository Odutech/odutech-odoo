<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Product Categories for Optical -->
        <record id="product_category_optical" model="product.category">
            <field name="name">Optical Products</field>
            <field name="parent_id" ref="product.product_category_all"/>
            <field name="property_cost_method">average</field>
            <field name="property_valuation">real_time</field>
        </record>
        
        <record id="product_category_frames" model="product.category">
            <field name="name">Frames</field>
            <field name="parent_id" ref="product_category_optical"/>
        </record>
        
        <record id="product_category_lenses" model="product.category">
            <field name="name">Lenses</field>
            <field name="parent_id" ref="product_category_optical"/>
        </record>
        
        <record id="product_category_accessories" model="product.category">
            <field name="name">Optical Accessories</field>
            <field name="parent_id" ref="product_category_optical"/>
        </record>
        
        <!-- Stock Locations -->
        <record id="location_central_lab" model="stock.location">
            <field name="name">Central Lab</field>
            <field name="usage">internal</field>
            <field name="location_type">central_lab</field>
        </record>
        
        <record id="location_clinic_dispensary" model="stock.location">
            <field name="name">Clinic Dispensary</field>
            <field name="usage">internal</field>
            <field name="location_type">clinic_dispensary</field>
        </record>
        
        <!-- Picking Types for Optical -->
        <record id="picking_type_clinic_to_lab" model="stock.picking.type">
            <field name="name">Clinic to Lab</field>
            <field name="code">internal</field>
            <field name="sequence_code">CLN/LAB</field>
            <field name="warehouse_id" eval="False"/>
            <field name="default_location_src_id" ref="location_clinic_dispensary"/>
            <field name="default_location_dest_id" ref="location_central_lab"/>
        </record>
    </data>
</odoo>