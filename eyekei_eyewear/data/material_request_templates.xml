<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_material_request_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="row">
                                <div class="col-12">
                                    <h2 class="text-center mb-4">Material Request Summary</h2>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-6">
                                    <strong>Request Number:</strong> <span t-field="doc.sequence_number"/><br/>
                                    <strong>Requested By:</strong> <span t-field="doc.user_id.name"/><br/>
                                    <strong>Requester Default WH:</strong>
                                    <span t-field="doc.user_id.default_warehouse_id.name" t-if="doc.user_id.default_warehouse_id"/>
                                    <span t-if="not doc.user_id.default_warehouse_id" class="text-muted">None Assigned</span><br/>

                                    <strong>Operating Company:</strong> <span t-field="doc.company_id.name"/>
                                </div>
                                <div class="col-6 text-end">
                                    <strong>Date Requested:</strong> <span t-field="doc.date_request" t-options="{'widget': 'date'}"/><br/>
                                    <strong>Expected Delivery:</strong> <span t-field="doc.date_expected" t-options="{'widget': 'date'}"/><br/>
                                    <strong>Status:</strong> <span t-field="doc.state"/>
                                </div>
                            </div>

                            <hr/>

                            <div class="row mb-4">
                                <div class="col-6">
                                    <strong>Origin Warehouse:</strong> <span t-field="doc.origin_warehouse_id.name" t-if="doc.origin_warehouse_id"/> <span t-if="not doc.origin_warehouse_id">Pending Allocation</span><br/>
                                    <strong>Origin Stock Room:</strong> <span t-field="doc.origin_location_id.name" t-if="doc.origin_location_id"/> <span t-if="not doc.origin_location_id">Pending Allocation</span>
                                </div>
                                <div class="col-6 text-end">
                                    <strong>Destination Warehouse:</strong> <span t-field="doc.warehouse_id.name"/><br/>
                                    <strong>Destination Location:</strong> <span t-field="doc.location_id.name"/>
                                </div>
                            </div>

                            <h4 class="mt-4">Requested Line Items</h4>
                            <table class="table table-sm table-striped border mt-2">
                                <thead style="background-color: #343a40; color: white;">
                                    <tr>
                                        <th style="width: 10%;">#</th>
                                        <th style="width: 65%;">Product Description</th>
                                        <th style="width: 25%;" class="text-end">Requested Qty</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="count" t-value="1"/>
                                    <t t-foreach="doc.request_line_ids" t-as="line">
                                        <tr>
                                            <td><t t-esc="count"/></td>
                                            <td><span t-field="line.product_id.display_name"/></td>
                                            <td class="text-end"><span t-field="line.qty_requested"/> Units</td>
                                        </tr>
                                        <t t-set="count" t-value="count + 1"/>
                                    </t>
                                </tbody>
                            </table>

                            <div class="row mt-5 pt-5">
                                <div class="col-6">
                                    <p class="border-top pt-2 text-center" style="width: 200px;">Requester Signature</p>
                                </div>
                                <div class="col-6 text-end">
                                    <p class="border-top pt-2 text-center ms-auto" style="width: 200px;">Authorized Approval</p>
                                </div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    <template id="portal_my_home_menu_inventory_request" name="Portal layout : Inventory Request Entries" inherit_id="portal.portal_breadcrumbs" priority="30">
            <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
                <li t-if="page_name == 'inventory_request'" class="breadcrumb-item active">
                    Inventory Requests
                </li>
            </xpath>
        </template>

    <template id="portal_my_home_inventory_request" name="Show Inventory Requests" inherit_id="portal.portal_my_home" priority="30">
            <xpath expr="//div[@id='portal_common_category']" position="inside">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                    <t t-set="title">Inventory Request</t>
                    <t t-set="text">View and track your material/inventory requests</t>
                    <t t-set="url" t-value="'/our/inventory/requests'"/>
                    <t t-set="placeholder_count" t-value="'inventory_request_count'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </xpath>
        </template>

    <template id="portal_my_inventory_requests_list" name="My Inventory Requests">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>

               <t t-call="portal.portal_searchbar">
            <t t-set="title">Inventory Requests</t>

                    <div class="form-inline ms-md-auto d-flex align-items-center gap-2">
                        <a href="/material/request" class="btn btn-primary">
                            <i class="fa fa-plus me-1"/> Create New Request
                        </a>
                    </div>
                </t>
                <t t-if="not requests">
                    <div class="alert alert-info" role="alert">
                        There are currently no inventory requests for your account.
                    </div>
                </t>

                <t t-if="requests" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Req Number</th>
                            <th>Requested By</th>
                            <th class="text-center">Date Request</th>
                            <th class="text-center">Expected Date</th>
                            <th>Origin Warehouse</th>
                            <th>Destination Warehouse</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="requests" t-as="req">
                            <tr>
                                <td>
                                    <a t-attf-href="/material/request/view/#{req.id}">
                                        <span t-field="req.sequence_number" class="fw-bold"/>
                                    </a>
                                </td>
                                <td>
                                    <span t-field="req.user_id.name"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="req.date_request" t-options="{'widget': 'date'}"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="req.date_expected" t-options="{'widget': 'date'}"/>
                                </td>
                                <td>
                                    <span t-field="req.origin_warehouse_id.name" t-if="req.origin_warehouse_id"/>
                                    <span class="text-muted" t-if="not req.origin_warehouse_id">-</span>
                                </td>
                                <td>
                                    <span t-field="req.warehouse_id.name"/>
                                </td>
                                <td class="text-center">
                                    <span t-if="req.state == 'draft'" class="badge rounded-pill bg-info">Draft</span>
                                    <span t-if="req.state == 'submitted'" class="badge rounded-pill bg-warning">Await Approval</span>
                                    <span t-if="req.state == 'approved'" class="badge rounded-pill bg-success">Approved</span>
                                    <span t-if="req.state == 'dispatched'" class="badge rounded-pill bg-primary">Dispatched</span>
                                    <span t-if="req.state == 'received'" class="badge rounded-pill bg-info">Received</span>
                                    <span t-if="req.state == 'confirmed'" class="badge rounded-pill bg-success">Confirmed</span>
                                    <span t-if="req.state == 'quantity_issue'" class="badge rounded-pill bg-danger">Quantity Issue</span>
                                    <span t-if="req.state == 'validated'" class="badge rounded-pill bg-success">Validated</span>
                                    <span t-if="req.state == 'done'" class="badge rounded-pill bg-secondary">Done</span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </template>

    <template id="material_request_submit_template" name="Submit Material Request">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <div class="container my-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-9">
                            <h2 class="mb-4">Transfer Inventory Request</h2>

                            <div t-if="error_fields" class="alert alert-danger shadow-sm d-flex align-items-start" role="alert">
                                <span class="oi oi-warning me-3 fs-4 mt-1"/>
                                <div>
                                    <h5 class="alert-heading mb-1 font-weight-bold">Submission Failed!</h5>
                                    <p class="mb-2 text-muted small">Please correct or populate the following mandatory configuration fields:</p>
                                    <ul class="mb-0 ps-3">
                                        <t t-set="field_labels" t-value="{
                                            'date_request': 'Date Requested',
                                            'date_expected': 'Expected Date',
                                            'warehouse_id': 'Destination Warehouse',
                                            'company_id': 'Company / Center'
                                        }"/>
                                        <t t-foreach="error_fields" t-as="error_field">
                                            <li class="font-weight-bold">
                                                <t t-esc="field_labels.get(error_field, error_field.replace('_', ' ').title())"/>
                                            </li>
                                        </t>
                                    </ul>
                                </div>
                            </div>

                            <form action="/material/request/create" method="post" class="bg-light p-4 rounded shadow-sm">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="date_request" class="form-label">Date Requested <span class="text-danger">*</span></label>
                                            <input type="date" name="date_request" id="date_request"
                                                   t-att-value="post.get('date_request') if post else datetime.date.today().strftime('%Y-%m-%d')"
                                                   t-attf-class="form-control #{'is-invalid' if 'date_request' in error_fields else ''}" required="1"/>
                                        </div>
                                        <div class="mb-3">
                                            <label for="warehouse_id" class="form-label">Destination Warehouse <span class="text-danger">*</span></label>
                                            <select name="warehouse_id" id="warehouse_id" t-attf-class="form-select #{'is-invalid' if 'warehouse_id' in error_fields else ''}" required="1">
                                                <option value="">Select Warehouse...</option>
                                                <t t-foreach="warehouses" t-as="wh">
                                                    <option t-att-value="wh.id" t-att-selected="post and int(post.get('warehouse_id', 0)) == wh.id">
                                                        <t t-esc="wh.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="date_expected" class="form-label">Expected Date <span class="text-danger">*</span></label>
                                            <input type="date" name="date_expected" id="date_expected"
                                                   t-att-value="post.get('date_expected')"
                                                   t-attf-class="form-control #{'is-invalid' if 'date_expected' in error_fields else ''}" required="1"/>
                                        </div>
                                        <div class="mb-3">
                                            <label for="priority" class="form-label">Priority</label>
                                            <select name="priority" id="priority" class="form-select">
                                                <t t-foreach="priorities" t-as="p">
                                                    <option t-att-value="p[0]" t-att-selected="post and post.get('priority') == p[0]">
                                                        <t t-esc="p[1]"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-4 border-top">
                                    <h4 class="mb-3">Requested Products</h4>
                                    <table class="table table-bordered align-middle" id="products_table">
                                        <thead class="table-secondary">
                                            <tr>
                                                <th style="width: 65%;">Product <span class="text-danger">*</span></th>
                                                <th style="width: 25%;">Quantity Requested <span class="text-danger">*</span></th>
                                                <th style="width: 10%;" class="text-center">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="product-row">
                                                <td>
                                                    <select name="product_ids[]" class="form-select" required="1">
                                                        <option value="">Select Product...</option>
                                                        <t t-foreach="products" t-as="product">
                                                            <option t-att-value="product.id"><t t-esc="product.display_name"/></option>
                                                        </t>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" name="quantities[]" class="form-control" min="0.01" step="any" placeholder="1.0" required="1"/>
                                                </td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-outline-danger btn-sm remove-row-btn"><i class="oi oi-close"/></button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="add_product_row_btn">
                                        <i class="oi oi-plus me-1"/> Add Product Line
                                    </button>
                                </div>

                                <div class="mt-4 pt-2 border-top text-end">
                                    <a href="/my" class="btn btn-secondary me-2">Cancel</a>
                                    <button type="submit" class="btn btn-primary px-4">Submit Request</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function () {
                    const addBtn = document.getElementById('add_product_row_btn');
                    const tableBody = document.querySelector('#products_table tbody');

                    if (addBtn &amp;&amp; tableBody) {
                        addBtn.addEventListener('click', function () {
                            const firstRow = tableBody.querySelector('.product-row');
                            if (firstRow) {
                                const newRow = firstRow.cloneNode(true);
                                newRow.querySelector('select').value = '';
                                newRow.querySelector('input').value = '';
                                tableBody.appendChild(newRow);
                            }
                        });

                        tableBody.addEventListener('click', function (e) {
                            if (e.target.closest('.remove-row-btn')) {
                                const rows = tableBody.querySelectorAll('.product-row');
                                if (rows.length > 1) {
                                    e.target.closest('.product-row').remove();
                                } else {
                                    alert('You must request at least one item.');
                                }
                            }
                        });
                    }
                });
            </script>
        </t>
    </template>

    <template id="material_request_success_template" name="Request Success">
    <t t-call="website.layout">
        <div id="wrap" class="container my-5 text-center">
            <h2>Request Submitted Successfully!</h2>
            <p>Reference: <t t-esc="material_request.sequence_number"/></p>
        </div>
    </t>
    </template>

    <template id="material_request_detail_template" name="Material Request Details">
        <t t-call="website.layout">
            <div id="wrap" class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-lg-10">

                        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                            <div>
                                <a href="/our/inventory/requests" class="text-decoration-none small text-muted"><i class="oi oi-chevron-left"/> Back to Account Portal</a>
                                <h2 class="mt-1">Request <t t-esc="req.sequence_number or 'Draft #' + str(req.id)"/></h2>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                            <t t-if="req.state != 'draft'">
                                <a t-attf-href="/material/request/download/#{req.id}" class="btn btn-outline-danger btn-sm shadow-sm" target="_blank">
                                    <i class="fa fa-file-pdf-o me-1"/> Download PDF Document
                                </a>
                            </t>
                            <span t-attf-class="badge #{badge_class} fs-6 px-3 py-2 rounded-pill">
                                <t t-esc="dict(req._fields['state'].selection).get(req.state)"/>
                            </span>
                        </div>
                        </div>

                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-white font-weight-bold">Configuration Specifications</div>
                            <div class="card-body bg-light">
                                <div class="row g-3">
                                    <div class="col-sm-6 col-md-3">
                                        <div class="text-muted small">Date Requested</div>
                                        <div class="font-weight-bold"><t t-esc="req.date_request"/></div>
                                    </div>
                                    <div class="col-sm-6 col-md-3">
                                        <div class="text-muted small">Expected Delivery</div>
                                        <div class="font-weight-bold"><t t-esc="req.date_expected"/></div>
                                    </div>
                                    <div class="col-sm-6 col-md-3">
                                        <div class="text-muted small">Destination Warehouse</div>
                                        <div class="font-weight-bold"><t t-esc="req.warehouse_id.name"/></div>
                                    </div>
                                    <div class="col-sm-6 col-md-3">
                                        <div class="text-muted small">Urgency Level</div>
                                        <div class="font-weight-bold">
                                            <t t-esc="dict(req._fields['priority'].selection).get(req.priority)"/>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 col-md-4 mt-3 pt-2 border-top">
                                        <div class="text-muted small">Fulfillment Source (Origin WH)</div>
                                        <div class="text-primary font-weight-bold"><t t-esc="req.origin_warehouse_id.name or 'Pending Allocation'"/></div>
                                    </div>
                                    <div class="col-sm-6 col-md-4 mt-3 pt-2 border-top">
                                        <div class="text-muted small">Source Stock Room</div>
                                        <div class="text-primary font-weight-bold"><t t-esc="req.origin_location_id.name or 'Pending Allocation'"/></div>
                                    </div>
                                    <div class="col-sm-12 col-md-4 mt-3 pt-2 border-top">
                                        <div class="text-muted small">Operating Company</div>
                                        <div class="font-weight-bold"><t t-esc="req.company_id.name"/></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h4 class="mb-3 mt-4">Requested Line Items Matrix</h4>
                        <div class="table-responsive bg-white rounded shadow-sm border mb-4">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th style="width: 10%;">#</th>
                                        <th style="width: 60%;">Product Description</th>
                                        <th style="width: 30%;" class="text-end">Requested Quantity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="count" t-value="1"/>
                                    <t t-foreach="req.request_line_ids" t-as="line">
                                        <tr>
                                            <td><t t-esc="count"/></td>
                                            <td><strong><t t-esc="line.product_id.display_name"/></strong></td>
                                            <td class="text-end font-weight-bold text-info"><t t-esc="line.qty_requested"/> Units</td>
                                        </tr>
                                        <t t-set="count" t-value="count + 1"/>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <div class="d-flex justify-content-end align-items-center gap-2 mt-4 pt-3 border-top">
                            <t t-if="req.state == 'draft'">
                                <a t-attf-href="/material/request/edit/#{req.id}" class="btn btn-outline-secondary px-4">
                                    <i class="oi oi-edit me-1"/> Edit Request
                                </a>

                                <form t-attf-action="/material/request/submit_action/#{req.id}" method="post" class="m-0">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                                        <i class="oi oi-check me-1"/> Submit for Approval
                                    </button>
                                </form>
                            </t>
                            <t t-elif="req.state == 'dispatched'">
                            <form t-attf-action="/material/request/discrepancy/#{req.id}" method="post" class="m-0">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-outline-danger px-4">
                                    <i class="oi oi-close me-1"/> Quantity Discrepancy
                                </button>
                            </form>

                            <form t-attf-action="/material/request/confirm_received/#{req.id}" method="post" class="m-0">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-success px-4 shadow-sm">
                                    <i class="oi oi-check me-1"/> Confirm Received
                                </button>
                            </form>
                        </t>
                            <t t-else="">
                                <div class="text-muted small me-auto"><i class="oi oi-lock me-1"/> This document is locked for modifications.</div>
                                <a href="/material/request" class="btn btn-primary px-4">Create New Request</a>
                            </t>
                        </div>

                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="material_request_edit_template" name="Edit Material Request">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <div class="container my-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-9">
                            <h2 class="mb-4">Modify Request: <t t-esc="req.sequence_number or 'Draft'"/></h2>

                            <form t-attf-action="/material/request/update/#{req.id}" method="post" class="bg-light p-4 rounded shadow-sm">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="date_request" class="form-label">Date Requested <span class="text-danger">*</span></label>
                                            <input type="date" name="date_request" id="date_request" class="form-control"
                                                   t-att-value="req.date_request" required="1"/>
                                        </div>
                                        <div class="mb-3">
                                            <label for="warehouse_id" class="form-label">Destination Warehouse <span class="text-danger">*</span></label>
                                            <select name="warehouse_id" id="warehouse_id" class="form-select" required="1">
                                                <t t-foreach="warehouses" t-as="wh">
                                                    <option t-att-value="wh.id" t-att-selected="wh.id == req.warehouse_id.id">
                                                        <t t-esc="wh.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="date_expected" class="form-label">Expected Date <span class="text-danger">*</span></label>
                                            <input type="date" name="date_expected" id="date_expected" class="form-control"
                                                   t-att-value="req.date_expected" required="1"/>
                                        </div>
                                        <div class="mb-3">
                                            <label for="company_id" class="form-label">Company / Center <span class="text-danger">*</span></label>
                                            <select name="company_id" id="company_id" class="form-select" required="1">
                                                <t t-foreach="companies" t-as="comp">
                                                    <option t-att-value="comp.id" t-att-selected="comp.id == req.company_id.id">
                                                        <t t-esc="comp.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="mb-3">
                                            <label for="priority" class="form-label">Priority</label>
                                            <select name="priority" id="priority" class="form-select">
                                                <t t-foreach="priorities" t-as="p">
                                                    <option t-att-value="p[0]" t-att-selected="p[0] == req.priority">
                                                        <t t-esc="p[1]"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-4 border-top">
                                    <h4 class="mb-3">Requested Products</h4>
                                    <table class="table table-bordered align-middle" id="products_table">
                                        <thead class="table-secondary">
                                            <tr>
                                                <th style="width: 65%;">Product <span class="text-danger">*</span></th>
                                                <th style="width: 25%;">Quantity Requested <span class="text-danger">*</span></th>
                                                <th style="width: 10%;" class="text-center">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="req.request_line_ids" t-as="line">
                                                <tr class="product-row">
                                                    <td>
                                                        <select name="product_ids[]" class="form-select" required="1">
                                                            <t t-foreach="products" t-as="product">
                                                                <option t-att-value="product.id" t-att-selected="product.id == line.product_id.id">
                                                                    <t t-esc="product.display_name"/>
                                                                </option>
                                                            </t>
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <input type="number" name="quantities[]" class="form-control" min="0.01" step="any"
                                                               t-att-value="line.qty_requested" required="1"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-outline-danger btn-sm remove-row-btn"><i class="oi oi-close"/></button>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="add_product_row_btn">
                                        <i class="oi oi-plus me-1"/> Add Product Line
                                    </button>
                                </div>

                                <div class="mt-4 pt-2 border-top text-end">
                                    <a t-attf-href="/material/request/view/#{req.id}" class="btn btn-secondary me-2">Discard Changes</a>
                                    <button type="submit" class="btn btn-primary px-4">Save Modifications</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function () {
                    const addBtn = document.getElementById('add_product_row_btn');
                    const tableBody = document.querySelector('#products_table tbody');

                    if (addBtn &amp;&amp; tableBody) {
                        addBtn.addEventListener('click', function () {
                            const firstRow = tableBody.querySelector('.product-row');
                            if (firstRow) {
                                const newRow = firstRow.cloneNode(true);
                                newRow.querySelector('select').value = '';
                                newRow.querySelector('input').value = '1.0';
                                tableBody.appendChild(newRow);
                            }
                        });

                        tableBody.addEventListener('click', function (e) {
                            if (e.target.closest('.remove-row-btn')) {
                                const rows = tableBody.querySelectorAll('.product-row');
                                if (rows.length > 1) {
                                    e.target.closest('.product-row').remove();
                                } else {
                                    alert('You must request at least one item.');
                                }
                            }
                        });
                    }
                });
            </script>
        </t>
    </template>
</odoo>