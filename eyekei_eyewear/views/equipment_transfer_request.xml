<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_material_request_tree" model="ir.ui.view">
        <field name="name">material.request.list</field>
        <field name="model">material.request</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-warning="state == 'quantity_issue'" decoration-success="state == 'done'">
                <field name="sequence_number"/>
                <field name="user_id" readonly="1"/>
                <field name="warehouse_id"/>
                <field name="location_id"/>
                <field name="origin_warehouse_id"/>
                <field name="origin_location_id"/>
                <field name="date_request"/>
                <field name="date_expected"/>
                <field name="company_id" optional="show"/>
                <field name="warehouse_id"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('draft', 'submitted')"
                       decoration-warning="state == 'quantity_issue'"
                       decoration-success="state in ('validated', 'done')"/>
            </list>
        </field>
    </record>

    <record id="view_material_request_form" model="ir.ui.view">
        <field name="name">material.request.form</field>
        <field name="model">material.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                <button name="action_submit_for_approval" string="Submit for Approval" type="object"  class="oe_highlight" invisible="state !='draft'"/>
                <!-- Shows Approve and Reject buttons when a request is pending inside the 'submitted' pool -->
                <button name="action_approve_transfer_request" string="Approve" type="object"  class="oe_highlight" invisible="state !='submitted'"/>
                <button name="action_reject_transfer_request" string="Reject" type="object" class="btn-danger" invisible="state !='submitted'"/>
                    <button name="action_material_request_mark_done" string="Mark as Done" type="object" class="oe_highlight" invisible="state !='confirmed'"/>
                <button name="action_dispatch_transfer_request" string="Dispatch" type="object" class="oe_highlight" invisible="state !='approved'"/>
                <!-- ... keep remainder of header workflow links identical ... -->
                <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done"/>
            </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="sequence_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_request" readonly="state !='draft'"/>
                            <field name="date_expected" readonly="state !='draft'"/>
                            <field name="user_id" readonly="1"/>
                            <field name="origin_warehouse_id" readonly="state !='draft'"/>
                            <field name="origin_location_id"  domain="[('warehouse_id', '=', warehouse_id)]" readonly="state !='draft'"/>
                            <field name="courier_name" readonly="state !='approved'" invisible="state not in ('approved','dispatched','confirmed','quantity_issue','done')"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="priority" widget="priority" readonly="state !='draft'"/>
                            <field name="warehouse_id" readonly="1"/>
                            <field name="location_id" domain="[('warehouse_id', '=', warehouse_id)]" readonly="state !='draft'"/>
                            <field name="rejection_reason" invisible="state not in ('submitted','rejected')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Requested Products" name="request_lines">
                            <field name="request_line_ids" readonly="state !='draft'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty_available" readonly="1" force_save="1"/>
                                    <field name="qty_requested"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_material_request_kanban" model="ir.ui.view">
        <field name="name">material.request.kanban</field>
        <field name="model">material.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="sequence_number"/>
                <field name="date_request"/>
                <field name="company_id"/>
                <field name="priority"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_details d-flex flex-column justify-content-between">
                                <div>
                                    <strong class="o_kanban_record_title">
                                        <field name="sequence_number"/>
                                    </strong>
                                    <div class="text-muted">
                                        Date: <field name="date_request"/>
                                    </div>
                                    <div t-if="record.company_id.raw_value" class="text-muted">
                                        Center: <field name="company_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom d-flex justify-content-between align-items-center mt-2">
                                    <field name="priority" widget="priority"/>
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'quantity_issue': 'danger', 'done': 'success'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_material_request" model="ir.actions.act_window">
        <field name="name">Material Requests</field>
        <field name="res_model">material.request</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first material request!
            </p>
        </field>
    </record>

    <record id="action_report_material_request" model="ir.actions.report">
        <field name="name">Material Request Document</field>
        <field name="model">material.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eyekei_eyewear.report_material_request_document</field>
        <field name="report_file">eyekei_eyewear.report_material_request_document</field>
        <field name="binding_model_id" ref="model_material_request"/>
        <field name="binding_type">report</field>
    </record>
    <menuitem id="menu_item_for_" name="Transfer Requests" parent="eyekei_eyewear.menu_lab_root" action="action_material_request"/>
</odoo>