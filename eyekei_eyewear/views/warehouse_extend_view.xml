<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_form_inherit_distribution" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit.distribution</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="/form//field[@name='code']" position="after">
                <field name="is_main_distribution_center"/>
              </xpath>
        </field>
    </record>
</odoo>