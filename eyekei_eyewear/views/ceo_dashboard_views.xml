<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- CEO Dashboard Action -->
        <record id="action_ceo_dashboard" model="ir.actions.client">
            <field name="name">CEO Dashboard</field>
            <field name="tag">eyekei_ceo_dashboard</field>
        </record>
        
        <!-- Traditional Pivot/Graph Views for detailed analysis -->
        <record id="view_ceo_dashboard_pivot" model="ir.ui.view">
            <field name="name">eyekei.ceo.dashboard.pivot</field>
            <field name="model">eyekei.ceo.dashboard</field>
            <field name="arch" type="xml">
                <pivot>
                    <field name="date" type="row"/>
                    <field name="branch_id" type="col"/>
                    <field name="total_revenue" type="measure"/>
                    <field name="conversion_rate" type="measure"/>
                    <field name="avg_turnaround_hours" type="measure"/>
                </pivot>
            </field>
        </record>
        
        <record id="view_ceo_dashboard_graph" model="ir.ui.view">
            <field name="name">eyekei.ceo.dashboard.graph</field>
            <field name="model">eyekei.ceo.dashboard</field>
            <field name="arch" type="xml">
                <graph type="line">
                    <field name="date" interval="day"/>
                    <field name="total_revenue" type="measure"/>
                </graph>
            </field>
        </record>
    </data>
</odoo>