        <!-- Clinical Error Report -->
        <record id="action_clinical_error_report" model="ir.actions.act_window">
            <field name="name">Clinical Error Report</field>
            <field name="res_model">eyekei.remake.order</field>
            <field name="view_mode">pivot,list,form</field>
            <field name="domain">[('remake_type', '=', 'clinical_error')]</field>
            <field name="context">{'group_by': ['responsible_optometrist_id']}</field>
        </record>

        <!-- Remake Pivot (Analytics) -->
        <record id="view_remake_order_pivot" model="ir.ui.view">
            <field name="name">eyekei.remake.order.pivot</field>
            <field name="model">eyekei.remake.order</field>
            <field name="arch" type="xml">
                <pivot>
                    <field name="create_date" type="row" interval="month" />
                    <field name="remake_type" type="col" />
                    <field name="cost_impact" type="measure" />
                    <field name="remake_cost" type="measure" />
                    <!-- <field name="__count" type="measure" string="Count"/> -->
                </pivot>
            </field>
        </record>

        <!-- Remake Action -->
        <record id="action_remake_order_list" model="ir.actions.act_window">
            <field name="name">Remake Orders</field>
            <field name="res_model">eyekei.remake.order</field>
            <field name="view_mode">list,form,pivot</field>
        </record>

        <!-- Remake Wizard (Quick Create) -->
        <record id="view_remake_wizard_form" model="ir.ui.view">
            <field name="name">eyekei.remake.wizard.form</field>
            <field name="model">eyekei.remake.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="patient_id" options="{'no_create': True, 'no_open': True}" />
                            <field name="original_visit_id" options="{'no_create': True, 'no_open': True}" />
                            <field name="reason_type" widget="radio" />
                            <field name="complaint_description" />
                            <field name="days_after_delivery" />
                        </group>
                        <group>
                            <field name="optometrist_id" invisible="reason_type != 'clinical_error'" />
                            <field name="requires_manager_approval" readonly="1" />
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_create_remake" string="Create Remake Order" type="object"
                            class="btn btn-primary" />
                        <button string="Cancel" class="btn btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>