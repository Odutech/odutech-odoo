        <!-- Lab Dashboard Action -->
        <record id="action_lab_dashboard" model="ir.actions.act_window">
            <field name="name">Lab Dashboard</field>
            <field name="res_model">eyekei.lab.job</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('state', 'not in', ['delivered', 'cancelled'])]</field>
            <field name="context">{'group_by': 'state'}</field>
        </record>

        <!-- Lab Reports -->
        <record id="action_lab_daily_consumption" model="ir.actions.act_window">
            <field name="name">Daily Lens Consumption</field>
            <field name="res_model">stock.move</field>
            <field name="view_mode">list,pivot</field>
            <field name="domain">[('is_optical_consumption', '=', True)]</field>
            <field name="context">{'group_by': ['date:day']}</field>
        </record>

    </data>
</odoo>