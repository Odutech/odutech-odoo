<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Lab Dashboard Kanban -->
        <record id="view_lab_job_dashboard" model="ir.ui.view">
            <field name="name">eyekei.lab.job.dashboard</field>
            <field name="model">eyekei.lab.job</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state"
                        group_create="false"
                        quick_create="false"
                        records_draggable="true"
                        js_class="eyekei_lab_dashboard">
                    <field name="state"/>
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="branch_id"/>
                    <field name="frame_product_id"/>
                    <field name="lens_product_id"/>
                    <field name="source_type"/>
                    <field name="is_remake"/>
                    <field name="priority"/>
                    <field name="external_vendor_id"/>
                    <field name="original_job_id"/>
                    <templates>
                        <!-- FIX: renamed from kanban-box to card (Odoo 17+) -->
                        <t t-name="card">
                            <div t-att-class="'oe_kanban_card oe_kanban_global_click ' + (record.is_remake.raw_value ? 'border-danger' : '') + ' ' + (record.priority.raw_value == 'urgent' ? 'border-warning' : '')">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <span t-esc="record.name.value"/>
                                            </strong>
                                            <div class="text-muted">
                                                <span t-esc="record.patient_id.value"/>
                                            </div>
                                        </div>
                                        <div>
                                            <span t-if="record.source_type.raw_value == 'external'"
                                                  class="badge bg-warning">EXT</span>
                                            <span t-if="record.is_remake.raw_value"
                                                  class="badge bg-danger">REMAKE</span>
                                            <span t-if="record.priority.raw_value == 'urgent'"
                                                  class="badge bg-warning">
                                                <i class="fa fa-exclamation" title="Urgent"/>
                                            </span>
                                        </div>
                                    </div>

                                    <div class="text-muted small mb-2">
                                        <div>
                                            <i class="fa fa-building" title="Branch"/>
                                            <span t-esc="record.branch_id.value"/>
                                        </div>
                                        <div>
                                            <i class="fa fa-glasses" title="Frame"/>
                                            <span t-esc="record.frame_product_id.value"/>
                                        </div>
                                        <div>
                                            <i class="fa fa-dot-circle-o" title="Lens"/>
                                            <span t-esc="record.lens_product_id.value"/>
                                        </div>
                                        <div t-if="record.source_type.raw_value == 'external'">
                                            <i class="fa fa-truck" title="External Vendor"/>
                                            <span t-esc="record.external_vendor_id.value"/>
                                        </div>
                                    </div>

                                    <div class="o_kanban_record_bottom">
                                        <!-- Draft -->
                                        <button name="action_receive_job"
                                                string="Receive"
                                                type="object"
                                                class="btn btn-primary btn-sm w-100"
                                                invisible="state != 'draft'"/>

                                        <!-- Received -->
                                        <div invisible="state != 'received'" class="d-grid gap-2">
                                            <button name="action_start_production"
                                                    string="Start Production"
                                                    type="object"
                                                    class="btn btn-primary btn-sm"/>
                                            <button name="action_lens_not_available"
                                                    string="Lens N/A"
                                                    type="object"
                                                    class="btn btn-warning btn-sm"/>
                                        </div>

                                        <!-- Waiting for Lens -->
                                        <button name="action_lens_arrived"
                                                string="Lens Arrived"
                                                type="object"
                                                class="btn btn-success btn-sm w-100"
                                                invisible="state != 'waiting_lens'"/>

                                        <!-- In Production -->
                                        <div invisible="state != 'in_production'" class="d-grid gap-2">
                                            <button name="action_qc_pass"
                                                    string="QC Pass"
                                                    type="object"
                                                    class="btn btn-success btn-sm"/>
                                            <button name="action_qc_fail"
                                                    string="QC Fail"
                                                    type="object"
                                                    class="btn btn-danger btn-sm"/>
                                        </div>

                                        <!-- QC -->
                                        <button name="action_ready_for_dispatch"
                                                string="Mark Ready"
                                                type="object"
                                                class="btn btn-primary btn-sm w-100"
                                                invisible="state != 'qc'"/>

                                        <!-- Ready -->
                                        <button name="action_dispatch"
                                                string="Dispatch"
                                                type="object"
                                                class="btn btn-primary btn-sm w-100"
                                                invisible="state != 'ready'"/>

                                        <!-- Dispatched -->
                                        <span invisible="state != 'dispatched'" class="text-info">
                                            <i class="fa fa-truck" title="In Transit"/> In Transit
                                        </span>

                                        <!-- Delivered -->
                                        <span invisible="state != 'delivered'" class="text-success">
                                            <i class="fa fa-check" title="Completed"/> Completed
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Lab Job Form -->
        <record id="view_lab_job_form" model="ir.ui.view">
            <field name="name">eyekei.lab.job.form</field>
            <field name="model">eyekei.lab.job</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_receive_job" string="Receive Job" type="object"
                                class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_assign_lens"
                                            string="Assign &amp; Deduct Stock"
                                            type="object"
                                            class="btn btn-primary"
                                            invisible="not lens_product_id or state != 'received'"/>
                        <button name="action_start_production" string="Start Production" type="object"
                                class="oe_highlight" invisible="state != 'received'"/>
                        <button name="action_lens_arrived" string="Lens Arrived" type="object"
                                class="oe_highlight" invisible="state != 'waiting_lens'"/>
                        <button name="action_sent_for_qc" string="Send to QC" type="object"
                                class="oe_highlight" invisible="state != 'in_production' or not stock_move_ids or qc_passed"/>
                        <button name="action_qc_fail" string="Fail QC" type="object"
                                            class="btn btn-danger"
                                            invisible="state != 'qc' or qc_passed"/>
                        <!-- <button name="action_qc_pass" string="QC Passed" type="object"
                                class="oe_highlight" invisible="state != 'qc' or not stock_move_ids"/> -->
                        <button name="action_ready_for_dispatch" string="Ready for Dispatch" type="object"
                                class="oe_highlight" invisible="state != 'qc' or not qc_passed"/>
                        <button name="action_dispatch" string="Dispatch to Clinic" type="object"
                                class="oe_highlight" invisible="state != 'ready'"/>
                        <button name="action_confirm_delivery" string="Confirm Delivery" type="object"
                                class="oe_highlight" invisible="state != 'dispatched'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,received,waiting_lens,in_production,qc,ready,dispatched,delivered"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_visit" type="object"
                                    class="oe_stat_button" icon="fa-calendar">
                                <span>Visit</span>
                            </button>
                            <button name="action_view_prescription" type="object"
                                    class="oe_stat_button" icon="fa-file-text">
                                <span>Prescription</span>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                            <field name="is_remake" invisible="1"/>
                            <div class="alert alert-danger" role="alert" invisible="not is_remake">
                                <strong>REMAKE JOB</strong> - Original:
                                <field name="original_job_id"/>
                            </div>
                        </div>

                        <group>
                            <group>
                                <field name="visit_id" readonly="1"/>
                                <field name="patient_id" readonly="1"/>
                                <field name="branch_id" readonly="1"/>
                                <field name="source_type" widget="radio" readonly="state not in ('draft','received')"/>
                                <field name="external_vendor_id"
                                       invisible="source_type != 'external'"/>
                                <field name="priority" widget="radio" readonly="state not in ('draft','received')"/>
                            </group>
                            <group>
                                <field name="technician_id" readonly="1"/>
                                <field name="received_date" readonly="1"/>
                                <field name="production_start" readonly="1"/>
                                <field name="production_end" readonly="1"/>
                                <field name="turnaround_hours" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Job Details">
                                <group>
                                    <field name="frame_product_id" readonly="1"/>
                                    <field name="prescription_id" readonly="1"/>
                                </group>
                            </page>
                            <page string="Lens Assignment">
                                <group>
                                    <field name="lens_product_id" readonly="1"/>
                                    <field name="lens_batch_number"/>
                                </group>
                            </page>
                            <page string="Quality Control">
                                <group>
                                    <field name="qc_passed" readonly="state != 'qc'"/>
                                    <field name="qc_notes" readonly="state != 'qc'"/>
                                    <field name="qc_checked_by" readonly="1"/>
                                </group>
                                <div class="d-flex gap-2 mt-2">
                                    <!-- <button name="action_qc_pass" string="Pass QC" type="object"
                                            class="btn btn-success"
                                            invisible="state != 'qc' or not qc_passed"/> -->
                                </div>
                            </page>
                            <page string="External Vendor" invisible="source_type != 'external'">
                                <group>
                                    <field name="external_cost"/>
                                    <field name="purchase_order_id" readonly="1"/>
                                    <field name="transport_cost"/>
                                    <field name="total_external_cost" readonly="1"/>
                                    <field name="external_cost_breakdown"/>
                                </group>
                            </page>
                            <page string="Stock Moves">
                                <field name="stock_move_ids" readonly="1">
                                    <list>
                                        <field name="reference"/>
                                        <field name="product_id"/>
                                        <field name="product_uom_qty"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Lab Prescription">
                                <group>
                                    <group string="Left Eye">
                                        <field name="od_sph"/>
                                        <field name="od_cyl"/>
                                        <field name="od_axis"/>
                                        <field name="od_add"/>
                                        <field name="od_va"/>
                                </group>
                                <group string="Right Eye">
                                   <field name="od_sph"/>
                                        <field name="os_cyl"/>
                                        <field name="os_axis"/>
                                        <field name="os_add"/>
                                        <field name="os_va"/>
                                </group>
                                </group>
                                <group>
                                     <group>
                                          <field name="lens_product_id_od"/>
                                        <field name="lens_type_od"/>
                                        <field name="lens_index_od"/>
                                        <field name="lens_coating_od"/>
                                    </group>
                                     <group>
                                          <field name="lens_product_id_os"/>
                                        <field name="lens_type_os"/>
                                        <field name="lens_index_os"/>
                                        <field name="lens_coating_os"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Lab Job List -->
        <record id="view_lab_job_list" model="ir.ui.view">
            <field name="name">eyekei.lab.job.list</field>
            <field name="model">eyekei.lab.job</field>
            <field name="arch" type="xml">
                <list decoration-danger="is_remake"
                      decoration-warning="state == 'waiting_lens'">
                    <field name="name"/>
                    <field name="patient_id"/>
                    <field name="branch_id"/>
                    <field name="frame_product_id"/>
                    <field name="lens_product_id"/>
                    <field name="state" widget="badge"/>
                    <field name="priority" widget="badge"/>
                    <field name="source_type"/>
                    <field name="turnaround_hours"/>
                    <field name="is_remake" column_invisible="1"/>
                </list>
            </field>
        </record>

