<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Product Template Form: Add Optical tab -->
        <record id="view_product_template_form_optical_inherit" model="ir.ui.view">
            <field name="name">product.template.form.optical.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <field name="type" position="after">
                    <field name="is_optical_product" widget="boolean_toggle"/>
                    <field name="optical_type" 
                           invisible="not is_optical_product"
                           required="is_optical_product"
                           widget="radio"/>
                </field>
                
                <xpath expr="//notebook" position="inside">
                    <page string="Optical Details" 
                          name="optical_details"
                          invisible="not is_optical_product">
                        
                        <!-- Frame Configuration -->
                        <group invisible="optical_type != 'frame'">
                            <group string="Frame Specifications">
                                <field name="frame_brand"/>
                                <field name="frame_type"/>
                                <field name="frame_color"/>
                                <field name="frame_size" placeholder="52-18-140"/>
                            </group>
                            <group string="Inventory">
                                <field name="optical_minimum_stock"/>
                                <field name="default_stock_location"/>
                            </group>
                        </group>
                        
                        <!-- Lens Configuration -->
                        <group invisible="optical_type != 'lens'">
                            <group string="Lens Specifications">
                                <field name="lens_type"/>
                                <field name="lens_index"/>
                                <field name="lens_coating"/>
                                <field name="lens_material"/>
                                <field name="lens_finish_type"/>
                                <field name="lens_power"/>
                            </group>
                            <group string="Tracking">
                                <field name="tracking" widget="radio"/>
                                <field name="optical_minimum_stock"/>
                                <field name="default_stock_location"/>
                            </group>
                        </group>
                        
                        <!-- Accessory Configuration -->
                        <group invisible="optical_type != 'accessory'">
                            <group>
                                <field name="categ_id" string="Accessory Category"/>
                            </group>
                        </group>
                    </page>
                </xpath>
                
                <!-- Update tracking field help text -->
                <field name="tracking" position="attributes">
                    <attribute name="help">For lenses, use Lots to track power batches. For frames, use Serial Numbers for individual tracking or None for bulk.</attribute>
                </field>
            </field>
        </record>
        
        <!-- Product list: Optical specific -->
        <record id="view_product_template_list_optical" model="ir.ui.view">
            <field name="name">product.template.list.optical</field>
            <field name="model">product.template</field>
            <field name="arch" type="xml">
                <list decoration-danger="qty_available &lt; optical_minimum_stock">
                    <field name="default_code"/>
                    <field name="name"/>
                    <field name="optical_type" widget="badge"/>
                    <field name="frame_brand" optional="show"/>
                    <field name="lens_type" optional="show"/>
                    <field name="qty_available"/>
                    <field name="optical_minimum_stock"/>
                    <field name="list_price"/>
                    <field name="standard_price"/>
                </list>
            </field>
        </record>
        
        <!-- Frame Selection Kanban (for visit) -->
        <record id="view_product_frame_kanban_select" model="ir.ui.view">
            <field name="name">product.product.frame.kanban.select</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="name"/>
                    <field name="frame_brand"/>
                    <field name="frame_type"/>
                    <field name="frame_color"/>
                    <field name="qty_available"/>
                    <field name="lst_price"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span t-esc="name"/>
                                        </strong>
                                        <div class="text-muted">
                                            <span t-esc="frame_brand"/>
                                        </div>
                                    </div>
                                    <div class="badge bg-primary" t-esc="lst_price"/>
                                </div>
                                <div class="text-muted">
                                    <div>Color: <field name="frame_color"/></div>
                                    <div>Size: <field name="frame_size"/></div>
                                    <div>Stock: <field name="qty_available"/></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Search View for Optical Products -->
        <record id="view_product_template_search_optical" model="ir.ui.view">
            <field name="name">product.template.search.optical</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_search_view"/>
            <field name="arch" type="xml">
                <filter name="services" position="after">
                    <separator/>
                    <filter name="optical_products" string="Optical Products" domain="[('is_optical_product', '=', True)]"/>
                    <filter name="frames" string="Frames" domain="[('optical_type', '=', 'frame')]"/>
                    <filter name="lenses" string="Lenses" domain="[('optical_type', '=', 'lens')]"/>
                    <filter name="low_stock" string="Low Stock" domain="[('qty_available', '&lt;', 'optical_minimum_stock')]"/>
                </filter>
                <group position="inside">
                    <filter string="Optical Type" name="optical_type" context="{'group_by': 'optical_type'}"/>
                    <filter string="Frame Brand" name="frame_brand" context="{'group_by': 'frame_brand'}"/>
                    <filter string="Lens Type" name="lens_type_group" context="{'group_by': 'lens_type'}"/>
                </group>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_optical_products" model="ir.actions.act_window">
            <field name="name">Optical Products</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="domain">[('is_optical_product', '=', True)]</field>
            <field name="context">{'default_is_optical_product': True, 'search_default_optical_products': 1}</field>
            <field name="view_ids" eval="[(5, 0, 0), 
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_product_template_list_optical')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('product.product_template_form_view')})]"/>
        </record>
        
    </data>
</odoo>