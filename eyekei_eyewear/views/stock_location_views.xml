<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View Inheritance -->
        <record id="view_stock_location_form_inherit_eyekei" model="ir.ui.view">
            <field name="name">stock.location.form.inherit.eyekei</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_form"/>
            <field name="arch" type="xml">
                <field name="usage" position="after">
                    <field name="location_type" 
                           widget="selection"
                           options="{'horizontal': true}"
                           invisible="usage not in ['internal', 'production', 'transit']"/>
                    <field name="is_optical_location" invisible="1"/>
                </field>
                
                <field name="company_id" position="after">
                    <field name="branch_id" 
                           options="{'no_create': True}"
                           invisible="usage not in ['internal', 'production', 'transit']"/>
                </field>
                
                <group name="additional_info" position="after">
                    <group string="EyeKei Eyewear Configuration" 
                           invisible="not is_optical_location">
                        <field name="location_type" widget="radio" options="{'horizontal': true}"/>
                        <field name="branch_id"/>
                        <field name="is_optical_location"/>
                    </group>
                </group>
            </field>
        </record>

        <!-- list View Inheritance -->
        <record id="view_stock_location_list_inherit_eyekei" model="ir.ui.view">
            <field name="name">stock.location.list.inherit.eyekei</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_tree2"/>
            <field name="arch" type="xml">
                <field name="usage" position="after">
                    <field name="location_type" optional="show"/>
                    <field name="branch_id" optional="show"/>
                </field>
            </field>
        </record>

