        <!-- Action for Optical Locations -->
        <record id="action_optical_locations" model="ir.actions.act_window">
            <field name="name">Optical Locations</field>
            <field name="res_model">stock.location</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_optical_location', '=', True)]</field>
            <field name="context">{'default_is_optical_location': True}</field>
        </record>

