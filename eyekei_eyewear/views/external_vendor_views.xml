        <!-- Action: Optical Vendors -->
        <record id="action_optical_vendor_partners" model="ir.actions.act_window">
            <field name="name">External Optical Labs</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_optical_vendor', '=', True)]</field>
            <!-- <field name="search_view_id" ref="view_optical_vendor_search"/> -->
            <field name="context">{
                'default_is_optical_vendor': True,
                'default_company_type': 'company',
                'default_supplier_rank': 1,
                'default_vendor_category': 'external_lab',
                'search_default_optical_vendors': 1
            }</field>
        </record>

        <!-- Action: All Suppliers -->
        <record id="action_suppliers_with_vendor_flag" model="ir.actions.act_window">
            <field name="name">Suppliers &amp; Vendors</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('supplier_rank', '&gt;', 0)]</field>
            <field name="context">{'res_partner_search_mode': 'supplier', 'default_is_company': True}</field>
        </record>

    </data>
