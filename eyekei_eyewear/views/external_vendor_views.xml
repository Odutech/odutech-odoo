<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Partner Form: Add Optical Vendor tab -->
        <record id="view_partner_form_optical_vendor" model="ir.ui.view">
            <field name="name">res.partner.form.optical.vendor</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <!-- Add checkbox after company_name field -->
                <xpath expr="//field[@name='company_name']" position="after">
                    <field name="is_optical_vendor"
                           widget="boolean_toggle"
                           invisible="company_type != 'company'"
                           options="{'autosave': True}"/>
                </xpath>

                <!-- Add Optical Lab Details tab -->
                <xpath expr="//notebook" position="inside">
                    <page string="Optical Lab Details"
                          name="optical_vendor"
                          invisible="not is_optical_vendor"
                          groups="eyekei_eyewear.group_eyekei_manager">
                        <group>
                            <group>
                                <field name="vendor_category" widget="radio"/>
                                <field name="optical_rating" widget="radio"/>
                                <field name="is_preferred_vendor"/>
                                <field name="requires_approval"/>
                            </group>
                            <group>
                                <field name="lab_coordinator_id"
                                       context="{'default_parent_id': id, 'default_type': 'contact'}"/>
                                <field name="average_turnaround_days" readonly="1"/>
                            </group>
                        </group>

                        <div class="o_horizontal_separator">Performance Statistics</div>

                        <div class="row g-3 mb-3">
                            <!-- Jobs Sent -->
                            <div class="col-3">
                                <div class="card bg-info text-white">
                                    <div class="card-body text-center">
                                        <h4><field name="optical_jobs_sent" readonly="1"/></h4>
                                        <div>Jobs Sent</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Completed -->
                            <div class="col-3">
                                <div class="card bg-success text-white">
                                    <div class="card-body text-center">
                                        <h4><field name="optical_jobs_completed" readonly="1"/></h4>
                                        <div>Completed</div>
                                    </div>
                                </div>
                            </div>

                            <!--
                                FIX: t-att-class with record.X.raw_value is kanban-only syntax.
                                In a form view, use two divs with invisible= to switch color.
                            -->
                            <!-- Remake Rate — danger when > 10% -->
                            <div class="col-3">
                                <div class="card bg-danger text-white"
                                     invisible="optical_remake_rate &lt;= 10">
                                    <div class="card-body text-center">
                                        <h4>
                                            <field name="optical_remake_rate" readonly="1"/>%
                                        </h4>
                                        <div>Remake Rate</div>
                                    </div>
                                </div>
                                <div class="card bg-warning text-white"
                                     invisible="optical_remake_rate &gt; 10">
                                    <div class="card-body text-center">
                                        <h4>
                                            <field name="optical_remake_rate" readonly="1"/>%
                                        </h4>
                                        <div>Remake Rate</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Complaints -->
                            <div class="col-3">
                                <div class="card bg-secondary text-white">
                                    <div class="card-body text-center">
                                        <h4><field name="optical_complaint_count" readonly="1"/></h4>
                                        <div>Complaints</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <group class="mt-4">
                            <button name="action_view_optical_jobs"
                                    string="View All Jobs"
                                    type="object"
                                    class="btn btn-primary"/>
                            <button name="action_view_vendor_performance_report"
                                    string="Performance Report"
                                    type="object"
                                    class="btn btn-secondary"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Optical Vendors List View -->
        <record id="view_optical_vendor_list" model="ir.ui.view">
            <field name="name">res.partner.optical.vendor.list</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list decoration-danger="optical_remake_rate > 10"
                      decoration-success="optical_rating == '4'"
                      decoration-warning="optical_rating == '2'">
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="email"/>
                    <field name="city"/>
                    <field name="optical_jobs_sent"/>
                    <field name="optical_remake_rate"/>
                    <field name="optical_rating"/>
                    <field name="is_preferred_vendor" widget="boolean_toggle"/>
                    <field name="requires_approval"/>
                </list>
            </field>
        </record>

