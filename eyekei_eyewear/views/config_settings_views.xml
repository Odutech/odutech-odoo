<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Configuration View inherited from base settings -->
        <record id="res_config_settings_view_form_eyekei" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.eyekei</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="EYEKEI" string="EYEKEI" name="eyekei" groups="eyekei_eyewear.group_eyekei_admin">

                        <!-- eTIMS Section -->
                        <block title="eTIMS Integration (Kenya Revenue Authority)" name="etims_setting_container">
                            <setting id="etims_enabled" string="Enable eTIMS" help="Automatic eTIMS invoice generation">
                                <field name="etims_enabled"/>
                                <div class="content-group" invisible="not etims_enabled">
                                    <div class="mt16">
                                        <field name="etims_api_url" placeholder="https://api.kra.go.kr/etims..." class="oe_inline"/>
                                    </div>
                                    <div class="mt8">
                                        <field name="etims_api_key" placeholder="API Key" class="oe_inline"/>
                                    </div>
                                    <div class="mt8">
                                        <field name="etims_pin" placeholder="KRA PIN" class="oe_inline"/>
                                    </div>
                                    <div class="mt8">
                                        <field name="etims_test_mode" class="oe_inline"/>
                                        <label for="etims_test_mode" string="Test Mode"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <!-- SMS Section -->
                        <block title="SMS Notifications" name="sms_setting_container">
                            <setting id="sms_enabled" string="Enable SMS" help="Send automated SMS to patients">
                                <field name="sms_enabled"/>
                                <div class="content-group" invisible="not sms_enabled">
                                    <div class="mt16">
                                        <field name="sms_provider" class="oe_inline"/>
                                    </div>
                                    <div class="mt8">
                                        <field name="sms_api_key" placeholder="API Key" class="oe_inline"/>
                                    </div>
                                    <div class="mt8">
                                        <field name="sms_sender_id" placeholder="EYEKEI" class="oe_inline"/>
                                    </div>
                                </div>
                            </setting>
                        </block>

                        <!-- Patient Registration -->
                        <block title="Patient Registration" name="patient_setting_container">
                            <setting string="Self-Registration" help="Allow QR code self-registration">
                                <field name="enable_self_registration"/>
                            </setting>
                            <setting string="Patient ID Format" help="Configure auto-generated patient IDs">
                                <div class="mt16">
                                    <label for="patient_id_prefix" string="Prefix" class="oe_inline"/>
                                    <field name="patient_id_prefix" class="oe_inline oe_ml-2"/>
                                </div>
                                <div class="mt8">
                                    <label for="patient_id_padding" string="Digits" class="oe_inline"/>
                                    <field name="patient_id_padding" class="oe_inline oe_ml-2"/>
                                </div>
                            </setting>
                        </block>

                        <!-- Clinical Settings -->
                        <block title="Clinical &amp; Warranty" name="clinical_setting_container">
                            <setting string="Lens Adaptation Period" help="Default warranty for lens issues">
                                <field name="lens_adaptation_days" class="oe_inline"/> days
                            </setting>
                            <setting string="Frame Warranty" help="Default warranty for frames">
                                <field name="frame_warranty_months" class="oe_inline"/> months
                            </setting>
                            <setting string="Max Remake %" help="Alert threshold per optometrist">
                                <field name="max_remake_percentage" class="oe_inline"/> %
                            </setting>
                        </block>

                        <!-- Lab Settings -->
                        <block title="Lab &amp; Production" name="lab_setting_container">
                            <setting string="External Lab" help="Allow external vendor jobs">
                                <field name="enable_external_lab"/>
                            </setting>
                            <setting string="Default Job Priority" help="Default priority for lab jobs">
                                <field name="job_priority"/>
                            </setting>
                            <setting string="Urgent Surcharge" help="Additional charge for urgent jobs">
                                <field name="urgent_job_surcharge" class="oe_inline"/> %
                            </setting>
                        </block>

                        <!-- Insurance Settings -->
                        <block title="Insurance" name="insurance_setting_container">
                            <setting string="Pre-Auth Validity" help="Default insurance authorization validity">
                                <field name="insurance_validity_days" class="oe_inline"/> days
                            </setting>
                        </block>

                    </app>
                </xpath>
            </field>
        </record>

        <!-- Configuration Menu Action -->
        <record id="action_eyekei_config_settings" model="ir.actions.act_window">
            <field name="name">Settings</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
            <field name="context">{'module': 'eyekei_base'}</field>
        </record>
    </data>
</odoo>
