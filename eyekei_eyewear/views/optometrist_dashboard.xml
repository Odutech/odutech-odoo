<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Optometrist Dashboard: Kanban View -->
        <record id="view_visit_optometrist_dashboard" model="ir.ui.view">
            <field name="name">eyekei.patient.visit.optometrist.dashboard</field>
            <field name="model">eyekei.patient.visit</field>
            <field name="arch" type="xml">
                <!--
                    FIX: js_class must match the key registered in the JS views registry.
                    JS registers as: registry.category("views").add("eyekei_optometrist_dashboard", ...)
                -->
                <kanban default_group_by="state" group_create="false" quick_create="false" records_draggable="false"
                    create="false" delete="false" js_class="eyekei_optometrist_dashboard">

                    <!-- FIX: declare all fields used in the kanban template -->
                    <field name="state" />
                    <field name="patient_id" />
                    <field name="phone" />
                    <field name="is_insurance" />
                    <field name="is_remake" />
                    <field name="visit_date" />
                    <field name="optometrist_id" />
                    <field name="patient_id_seq" />
                    <field name="original_visit_id" />

                    <templates>
                        <t t-name="card">
                            <div
                                t-att-class="'oe_kanban_card oe_kanban_global_click ' + (record.is_remake.raw_value ? 'border-danger' : '')">
                                <div class="oe_kanban_content">

                                    <div class="o_kanban_record_top mb-2">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <span t-esc="record.patient_id.value" />
                                            </strong>
                                            <div class="text-muted">
                                                <small>
                                                    <field name="patient_id_seq" /></small>
                                            </div>
                                        </div>
                                        <div>
                                            <span t-if="record.is_insurance.raw_value"
                                                class="badge bg-info me-1">INS</span>
                                            <span t-if="record.is_remake.raw_value"
                                                class="badge bg-danger">REMAKE</span>
                                        </div>
                                    </div>

                                    <div class="text-muted mb-2">
                                        <div>
                                            <i class="fa fa-phone" title="Phone" />
                                            <span t-esc="record.phone.value" />
                                        </div>
                                        <div>
                                            <i class="fa fa-clock-o" title="Visit Date" />
                                            <field name="visit_date" />
                                        </div>
                                        <div t-if="record.is_remake.raw_value" class="text-danger">
                                            <small>Original:
                                                <field name="original_visit_id" /></small>
                                        </div>
                                    </div>

                                    <div class="o_kanban_record_bottom">

                                        <!-- Waiting -->
                                        <button name="action_start_consultation" string="Start" type="object"
                                            class="btn btn-primary btn-sm w-100" invisible="state != 'waiting'" />

                                        <!-- In Consultation -->
                                        <div invisible="state != 'in_consultation'" class="d-grid gap-2">
                                            <button name="action_open_prescription" string="Enter Prescription"
                                                type="object" class="btn btn-primary btn-sm" />
                                            <button name="action_prescription_complete" string="Complete" type="object"
                                                class="btn btn-success btn-sm" />
                                        </div>

                                        <!-- Pending Insurance -->
                                        <div invisible="state != 'pending_insurance'" class="d-grid gap-2">
                                            <button name="action_upload_insurance_docs" string="Upload Docs"
                                                type="object" class="btn btn-info btn-sm" />
                                            <button name="action_approve_insurance" string="Approved" type="object"
                                                class="btn btn-success btn-sm" />
                                            <button name="action_reject_insurance" string="Rejected" type="object"
                                                class="btn btn-danger btn-sm" />
                                        </div>

                                        <!-- Approved — Ready for Lab -->
                                        <button name="action_send_to_lab" string="Send to Lab" type="object"
                                            class="btn btn-primary btn-sm w-100" invisible="state != 'approved'" />

                                        <!-- Ready for Collection -->
                                        <button name="action_close_visit" string="Close &amp; Collect" type="object"
                                            class="btn btn-success btn-sm w-100"
                                            invisible="state != 'ready_collection'" />

                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Quick Prescription Form (Popup) -->
        <record id="view_prescription_quick_form" model="ir.ui.view">
            <field name="name">eyekei.prescription.quick.form</field>
            <field name="model">eyekei.prescription</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="row">
                            <div class="col-6">
                                <h4>Right Eye (OD)</h4>
                                <group>
                                    <field name="od_sph" />
                                    <field name="od_cyl" />
                                    <field name="od_axis" />
                                    <field name="od_add" />
                                </group>
                            </div>
                            <div class="col-6">
                                <h4>Left Eye (OS)</h4>
                                <group>
                                    <field name="os_sph" />
                                    <field name="os_cyl" />
                                    <field name="os_axis" />
                                    <field name="os_add" />
                                </group>
                            </div>
                        </div>
                        <group>
                            <field name="lens_type" />
                            <field name="lens_product_id" />
                            <field name="pd" />
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_save_and_duplicate" string="Save &amp; Create Insurance Copy" type="object"
                            class="btn btn-primary" />
                        <button name="action_save_only" string="Save Only" type="object" class="btn btn-secondary" />
                        <button string="Cancel" class="btn btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <!-- Optometrist Dashboard Action -->
        <record id="action_optometrist_dashboard" model="ir.actions.act_window">
            <field name="name">Optometrist Dashboard</field>
            <field name="res_model">eyekei.patient.visit</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[
                ('state', 'not in', ['draft', 'cancelled']),
                ('branch_id', 'in', allowed_company_ids),
                '|', ('optometrist_id', '=', False), ('optometrist_id', '=', uid)
                ]</field>
            <field name="context">{
                'search_default_waiting': 1,
                'create': False
            }</field>
        </record>

        <!-- Search View for Optometrist -->
        <record id="view_visit_optometrist_search" model="ir.ui.view">
            <field name="name">eyekei.patient.visit.optometrist.search</field>
            <field name="model">eyekei.patient.visit</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="patient_id" />
                    <field name="phone" />
                    <filter string="Waiting" name="waiting" domain="[('state', '=', 'waiting')]" />
                    <filter string="In Consultation" name="consultation" domain="[('state', '=', 'in_consultation')]" />
                    <filter string="Pending Insurance" name="pending_insurance"
                        domain="[('state', '=', 'pending_insurance')]" />
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]" />
                    <filter string="My Patients" name="my_patients" domain="[('optometrist_id', '=', uid)]" />
                    <filter string="Insurance" name="insurance" domain="[('is_insurance', '=', True)]" />
                    <filter string="Remakes" name="remakes" domain="[('is_remake', '=', True)]" />
                </search>
            </field>
        </record>

    </data>
</odoo>