<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit Company Form -->
        <record id="view_company_form_eyekei" model="ir.ui.view">
            <field name="name">res.company.form.eyekei</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="EYEKEI Portal" name="eyekei_portal">
                        <group>
                            <group>
                                <button name="action_generate_registration_qr" 
                                        string="Generate QR Code" 
                                        type="object" 
                                        class="btn btn-primary"
                                        icon="fa-qrcode"/>
                                <button name="action_download_qr" 
                                        string="Download QR Code" 
                                        type="object" 
                                        class="btn btn-primary"
                                        icon="fa-download"/>
                            </group>
                            <field name="registration_qr_code" widget="image" 
                                   readonly="1" colspan="2"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>