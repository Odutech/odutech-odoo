<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- INSURANCE COMPANY VIEWS -->
    <!-- ============================================ -->
    
    <record id="view_insurance_company_list" model="ir.ui.view">
        <field name="name">eyekei.insurance.company.list</field>
        <field name="model">eyekei.insurance.company</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="contact_person"/>
                <field name="phone"/>
                <field name="total_claims"/>
                <field name="pending_amount"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    
    <record id="view_insurance_company_form" model="ir.ui.view">
        <field name="name">eyekei.insurance.company.form</field>
        <field name="model">eyekei.insurance.company</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Insurance Company Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="contact_person"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="average_payment_days"/>
                            <field name="total_claims"/>
                            <field name="pending_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address">
                            <field name="address" placeholder="Full Address..."/>
                        </page>
                        <page string="Payment Terms">
                            <field name="payment_terms" placeholder="Payment terms and conditions..."/>
                        </page>
                        <page string="Schemes">
                            <field name="scheme_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="coverage_percentage"/>
                                    <field name="max_amount_per_claim"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <record id="action_insurance_company" model="ir.actions.act_window">
        <field name="name">Insurance Companies</field>
        <field name="res_model">eyekei.insurance.company</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================ -->
    <!-- INSURANCE CLAIM UPDATED VIEWS -->
    <!-- ============================================ -->
    
    <record id="view_insurance_claim_list" model="ir.ui.view">
        <field name="name">eyekei.insurance.claim.list</field>
        <field name="model">eyekei.insurance.claim</field>
        <field name="arch" type="xml">
            <list decoration-muted="state in ('rejected', 'reconciled')"
                  decoration-success="state == 'payment_received'"
                  decoration-warning="has_short_payment == True">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="insurance_company_id"/>
                <field name="scheme_id"/>
                <field name="member_number"/>
                <field name="billed_amount"/>
                <field name="amount_received"/>
                <field name="balance_due"/>
                <field name="state"/>
                <field name="aging_bucket"/>
                <field name="has_short_payment" invisible="1"/>
            </list>
        </field>
    </record>
    
    <record id="view_insurance_claim_form" model="ir.ui.view">
        <field name="name">eyekei.insurance.claim.form</field>
        <field name="model">eyekei.insurance.claim</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_documents_received" 
                            string="Documents Received" 
                            type="object" 
                            invisible="state != 'billing_finished'"
                            class="oe_highlight"/>
                    <button name="action_prepare_submission" 
                            string="Prepare Submission" 
                            type="object" 
                            invisible="state != 'docs_received'"
                            class="oe_highlight"/>
                    <button name="action_submit" 
                            string="Submit Claim" 
                            type="object" 
                            invisible="state != 'preparing_submission'"
                            class="oe_highlight"/>
                    <button name="action_send_to_insurance" 
                            string="Send to Insurance" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-envelope-o"
                            invisible="state not in ['preparing_submission', 'submitted']"
                            help="Send email to insurance company with all attached documents"/>
                    <button name="action_create_customer_invoice" 
                            string="Create Invoice" 
                            type="object" 
                            class="btn-secondary"
                            invisible="invoice_id"/>
                    <button name="action_register_insurance_payment" 
                            string="Register Payment" 
                            type="object" 
                            class="oe_highlight"
                            invisible="not invoice_id or balance_due &lt; 0.01"/>
                    <button name="action_reconcile" 
                            string="Reconcile" 
                            type="object" 
                            invisible="state != 'payment_received'"
                            class="oe_highlight"/>
                    <button name="move_to_billed" 
                            string="Move to Billed" 
                            type="object" 
                            invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="billing_finished,docs_received,preparing_submission,submitted,payment_received,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-file-text-o"
                                invisible="not invoice_id">
                            <span>Invoice</span>
                        </button>
                        <button name="action_view_payments" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-money"
                                invisible="not payment_ids">
                            <field name="amount_received" widget="statinfo" string="Received"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Patient &amp; Visit">
                            <field name="patient_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="visit_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="invoice_number" invisible="1"/>
                        </group>
                        <group string="Insurance Details">
                            <field name="insurance_company_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="scheme_id" 
                                   domain="[('insurance_company_id', '=', insurance_company_id)]"/>
                            <field name="member_number"/>
                        </group>
                    </group>
                    <group string="Financial">
                        <group>
                            <field name="invoice_id" readonly="1"/>
                            <field name="billed_amount"/>
                            <field name="amount_received"/>
                            <field name="balance_due"/>
                        </group>
                        <group>
                            <field name="adjustment_amount"/>
                            <field name="out_pocket_amount"/>
                            <field name="insurance_approved_amount"/>
                            <field name="short_payment_reason" 
                                   required="has_short_payment" 
                                   invisible="not has_short_payment"/>
                            <field name="has_short_payment" invisible="1"/>
                        </group>
                    </group>
                    <group string="Dates &amp; Tracking">
                        <group>
                            <field name="bill_closed_date"/>
                            <field name="docs_received_date"/>
                            <field name="received_by"/>
                            <field name="submission_date"/>
                        </group>
                        <group>
                            <field name="submission_batch_id"/>
                            <field name="payment_date"/>
                            <field name="aging_days"/>
                            <field name="aging_bucket"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents">
                            <field name="document_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Invoice Lines">
                            <field name="eyekei_insurance_claim_line_id" readonly="1">
                                <list>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="tax_ids"/>
                                    <field name="price_total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payments">
                            <field name="payment_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="journal_id"/>
                                    <field name="amount"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="eTIMS">
                            <group>
                                <field name="etims_number"/>
                                <field name="vat_number"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_insurance_claims" model="ir.actions.act_window">
        <field name="name">Insurance Claims</field>
        <field name="res_model">eyekei.insurance.claim</field>
        <field name="view_mode">list,form</field>
    </record>
    
    
    <!-- ============================================ -->
    <!-- SUBMISSION BATCH VIEWS -->
    <!-- ============================================ -->
    
    <record id="view_submission_batch_form" model="ir.ui.view">
        <field name="name">eyekei.submission.batch.form</field>
        <field name="model">eyekei.submission.batch</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_pdf" 
                            string="Generate PDF" 
                            type="object" 
                            invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_submit_batch" 
                            string="Submit Batch" 
                            type="object" 
                            invisible="state != 'generated'"
                            class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="insurance_company_id"/>
                            <field name="submission_date"/>
                        </group>
                        <group>
                            <field name="claim_count"/>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <field name="claim_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="patient_id"/>
                            <field name="billed_amount"/>
                            <field name="state"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- INSURANCE DASHBOARDS (Kanban Views) -->
    <!-- ============================================ -->
    
    <record id="view_insurance_claim_kanban" model="ir.ui.view">
        <field name="name">eyekei.insurance.claim.kanban</field>
        <field name="model">eyekei.insurance.claim</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="insurance_company_id"/>
                <field name="billed_amount"/>
                <field name="balance_due"/>
                <field name="aging_bucket"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div><field name="patient_id"/></div>
                                <div><field name="insurance_company_id"/></div>
                                <div class="o_kanban_record_bottom">
                                    <span class="oe_kanban_amount">
                                        Billed: <field name="billed_amount"/>
                                    </span>
                                    <span class="oe_kanban_balance" invisible="balance_due &lt;= 0">
                                        Balance: <field name="balance_due"/>
                                    </span>
                                </div>
                                <div t-if="record.aging_bucket.raw_value">
                                    <span class="badge badge-warning">
                                        <field name="aging_bucket"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>