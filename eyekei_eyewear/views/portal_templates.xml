<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Main Registration Template - Odoo 17 Bootstrap 5 -->
        <template id="patient_registration_template" name="EYEKEI Patient Registration">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">
                    <div class="container py-5">
                        <div class="row justify-content-center">
                            <div class="col-lg-8 col-md-10">

                                <!-- Header Card -->
                                <div class="card border-0 shadow-lg mb-4 bg-primary text-white">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-warning rounded p-3 me-3">
                                                    <i class="fa fa-eye fa-2x text-primary"></i>
                                                </div>
                                                <div>
                                                    <h2 class="mb-0 fw-bold">EYEKEI</h2>
                                                    <p class="mb-0 opacity-75">Patient Self-Registration</p>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-warning text-dark p-2 fs-6">
                                                    <i class="fa fa-hospital-o me-1"></i>
                                                    <t t-esc="branch.name" />
                                                </span>
                                                <!-- <div class="small mt-1" t-esc="branch.name" /> -->
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Registration Form Card -->
                                <div class="card border-0 shadow">
                                    <div class="card-body p-4 p-md-5">
                                        <h4 class="mb-4 text-primary">New Patient Registration</h4>

                                        <!-- Alert Container -->
                                        <div id="alert-container"></div>

                                        <!-- Duplicate Warning (Hidden by default) -->
                                        <div id="duplicate-warning" class="alert alert-warning d-none">
                                            <h5><i class="fa fa-exclamation-triangle"></i> Existing Patient Found</h5>
                                            <p>A patient with this phone number already exists.</p>
                                            <div class="bg-light p-3 rounded mb-3">
                                                <p class="mb-1"><strong>Patient ID:</strong> <span
                                                        id="dup-patient-id"></span></p>
                                                <p class="mb-1"><strong>Name:</strong> <span id="dup-name"></span></p>
                                                <p class="mb-1"><strong>Last Visit:</strong> <span
                                                        id="dup-last-visit"></span></p>
                                                <p class="mb-0"><strong>Branch:</strong> <span id="dup-branch"></span>
                                                </p>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <a id="dup-profile-link" href="#" class="btn btn-warning">
                                                    <i class="fa fa-external-link"></i> View Profile
                                                </a>
                                                <button type="button" class="btn btn-outline-secondary"
                                                    onclick="document.getElementById('duplicate-warning').classList.add('d-none')">
                                                    Continue Anyway
                                                </button>
                                            </div>
                                        </div>

                                        <!-- IMPORTANT: novalidate prevents browser default validation, we use Bootstrap -->
                                        <owl-component 
                                        name="eyekei_eyewear.portal_registration"
                                        t-props="{
                                            'branch_code': branch_code,
                                            'branch_name': branch.name,
                                            'csrf_token': csrf_token
                                        }"/>

                                    </div>
                                </div>

                                <!-- Footer -->
                                <div class="text-center mt-4 text-muted">
                                    <small>
                                        © 2026 EYEKEI Optical Care. All rights reserved.<br />
                                        Branch ID:
                                        <t t-esc="branch_code" /> |
                                        Session:
                                        <t t-esc="request.session.sid[:8]" />
                                    </small>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <!-- Success Template -->
        <template id="registration_success_template" name="Registration Success">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">
                    <div class="container py-5">
                        <div class="row justify-content-center">
                            <div class="col-md-8 text-center">
                                <div class="card border-0 shadow-lg">
                                    <div class="card-body p-5">
                                        <div class="mb-4">
                                            <i class="fa fa-check-circle text-success display-1"></i>
                                        </div>
                                        <h2 class="mb-3">Registration Successful!</h2>
                                        <p class="lead text-muted mb-4">
                                            Your patient profile has been created successfully.
                                        </p>

                                        <div class="bg-light p-4 rounded mb-4">
                                            <p class="text-muted mb-1">Your Patient ID</p>
                                            <h3 class="text-primary fw-bold font-monospace"
                                                t-esc="patient.patient_id" />
                                        </div>

                                        <div class="alert alert-info d-flex align-items-start">
                                            <i class="fa fa-info-circle me-2 mt-1"></i>
                                            <div class="text-start">
                                                A confirmation SMS has been sent to your phone number.
                                                Please proceed to the reception desk for verification.
                                            </div>
                                        </div>

                                        <div class="mt-4">
                                            <a href="/" class="btn btn-primary btn-lg px-5">
                                                <i class="fa fa-home"></i> Return to Home
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 text-muted">
                                    <small>
                                        Registered at
                                        <t t-esc="branch.name" /> on
                                        <t t-esc="patient.registration_date" t-options="{'widget': 'datetime'}" />
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <!-- Invalid Branch Template -->
        <template id="invalid_branch" name="Invalid Branch">
            <t t-call="website.layout">
                <div class="container py-5 text-center">
                    <div class="alert alert-danger">
                        <h3><i class="fa fa-exclamation-circle"></i> Invalid Branch</h3>
                        <p t-esc="error_message" />
                    </div>
                    <a href="/" class="btn btn-primary">Go Home</a>
                </div>
            </t>
        </template>

        <!-- Registration Disabled Template -->
        <template id="registration_disabled" name="Registration Disabled">
            <t t-call="website.layout">
                <div class="container py-5 text-center">
                    <div class="alert alert-warning">
                        <h3><i class="fa fa-ban"></i> Registration Disabled</h3>
                        <p>Self-registration is currently disabled for
                            <t t-esc="branch_name" />.</p>
                        <p>Please visit the reception desk to register.</p>
                    </div>
                    <a href="/" class="btn btn-primary">Go Home</a>
                </div>
            </t>
        </template>

        <!-- Patient Portal View -->
        <template id="patient_portal_view" name="My Patient Profile">
            <t t-call="portal.portal_layout">
                <div class="container py-4">
                    <div class="row">
                        <div class="col-12">
                            <h2>My Patient Profile</h2>
                            <hr />

                            <div class="card">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">
                                        <i class="fa fa-user"></i>
                                        <t t-esc="patient.name" />
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <table class="table table-borderless">
                                                <tr>
                                                    <td class="fw-bold">Patient ID:</td>
                                                    <td t-esc="patient.patient_id" />
                                                </tr>
                                                <tr>
                                                    <td class="fw-bold">Date of Birth:</td>
                                                    <td t-esc="patient.date_of_birth" />
                                                </tr>
                                                <tr>
                                                    <td class="fw-bold">Gender:</td>
                                                    <td t-esc="patient.gender" />
                                                </tr>
                                                <tr>
                                                    <td class="fw-bold">Phone:</td>
                                                    <td t-esc="patient.phone" />
                                                </tr>
                                            </table>
                                        </div>
                                        <div class="col-md-6">
                                            <table class="table table-borderless">
                                                <tr>
                                                    <td class="fw-bold">Branch:</td>
                                                    <td t-esc="patient.branch_id.name" />
                                                </tr>
                                                <tr>
                                                    <td class="fw-bold">Registration Date:</td>
                                                    <td t-esc="patient.registration_date" />
                                                </tr>
                                                <tr>
                                                    <td class="fw-bold">Status:</td>
                                                    <td>
                                                        <span t-if="patient.state == 'pending'"
                                                            class="badge bg-warning text-dark">Pending</span>
                                                        <span t-if="patient.state == 'verified'"
                                                            class="badge bg-success">Verified</span>
                                                        <span t-if="patient.state == 'rejected'"
                                                            class="badge bg-danger">Rejected</span>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>

    </data>
</odoo>