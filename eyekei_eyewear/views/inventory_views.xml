<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Frame Form -->
        <record id="view_inventory_frame_form" model="ir.ui.view">
            <field name="name">eyekei.inventory.frame.form</field>
            <field name="model">eyekei.inventory.frame</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="alert alert-danger" role="alert" invisible="not low_stock_alert">
                            <strong>Low Stock Alert!</strong> This frame is below minimum stock level.
                        </div>
                        
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                            <h3><field name="frame_id" readonly="1"/></h3>
                        </div>
                        
                        <group>
                            <group>
                                <field name="brand"/>
                                <field name="frame_type"/>
                                <field name="color"/>
                                <field name="size"/>
                            </group>
                            <group>
                                <field name="branch_id"/>
                                <field name="supplier_id"/>
                                <field name="is_active" widget="boolean_toggle"/>
                            </group>
                        </group>
                        
                        <div class="o_horizontal_separator">Pricing</div>
                        <group>
                            <field name="purchase_price"/>
                            <field name="selling_price"/>
                        </group>
                        
                        <div class="o_horizontal_separator">Stock Levels</div>
                        <group>
                            <group>
                                <field name="quantity_available"/>
                                <field name="quantity_reserved"/>
                                <field name="quantity_on_hand" readonly="1"/>
                            </group>
                            <group>
                                <field name="minimum_stock"/>
                                <field name="low_stock_alert" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Frame list -->
        <record id="view_inventory_frame_list" model="ir.ui.view">
            <field name="name">eyekei.inventory.frame.list</field>
            <field name="model">eyekei.inventory.frame</field>
            <field name="arch" type="xml">
                <list decoration-danger="low_stock_alert">
                    <field name="frame_id"/>
                    <field name="name"/>
                    <field name="brand"/>
                    <field name="frame_type"/>
                    <field name="quantity_available"/>
                    <field name="quantity_on_hand"/>
                    <field name="selling_price"/>
                    <field name="branch_id"/>
                    <field name="low_stock_alert" invisible="1"/>
                </list>
            </field>
        </record>
        
        <!-- Frame Search -->
        <record id="view_inventory_frame_search" model="ir.ui.view">
            <field name="name">eyekei.inventory.frame.search</field>
            <field name="model">eyekei.inventory.frame</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="brand"/>
                    <field name="frame_id"/>
                    <filter string="Low Stock" name="low_stock" domain="[('low_stock_alert', '=', True)]"/>
                    <filter string="My Branch" name="my_branch" domain="[('branch_id', '=', allowed_company_ids)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Brand" name="brand" context="{'group_by': 'brand'}"/>
                        <filter string="Type" name="type" context="{'group_by': 'frame_type'}"/>
                        <filter string="Branch" name="branch" context="{'group_by': 'branch_id'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Lens Form -->
        <record id="view_inventory_lens_form" model="ir.ui.view">
            <field name="name">eyekei.inventory.lens.form</field>
            <field name="model">eyekei.inventory.lens</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="alert alert-danger" role="alert" invisible="not low_stock_alert">
                            <strong>Low Stock Alert!</strong> This lens is below minimum stock level.
                        </div>
                        
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                            <h3><field name="lens_id" readonly="1"/></h3>
                        </div>
                        
                        <group>
                            <group>
                                <field name="brand"/>
                                <field name="lens_type"/>
                                <field name="index"/>
                                <field name="coating_type"/>
                                <field name="power_range"/>
                            </group>
                            <group>
                                <field name="location"/>
                                <field name="clinic_branch_id" invisible="location != 'clinic'"/>
                                <field name="supplier_id"/>
                            </group>
                        </group>
                        
                        <div class="o_horizontal_separator">Stock</div>
                        <group>
                            <field name="quantity_available"/>
                            <field name="quantity_reserved"/>
                            <field name="minimum_stock"/>
                            <field name="purchase_price"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Lens list -->
        <record id="view_inventory_lens_list" model="ir.ui.view">
            <field name="name">eyekei.inventory.lens.list</field>
            <field name="model">eyekei.inventory.lens</field>
            <field name="arch" type="xml">
                <list decoration-danger="low_stock_alert">
                    <field name="lens_id"/>
                    <field name="name"/>
                    <field name="lens_type"/>
                    <field name="index"/>
                    <field name="quantity_available"/>
                    <field name="location"/>
                    <field name="clinic_branch_id"/>
                </list>
            </field>
        </record>
        
        <!-- Stock Movement list -->
        <record id="view_stock_movement_list" model="ir.ui.view">
            <field name="name">eyekei.stock.movement.list</field>
            <field name="model">eyekei.stock.movement</field>
            <field name="arch" type="xml">
                <list decoration-success="movement_type == 'purchase'" 
                      decoration-danger="movement_type in ['deduct', 'sale']"
                      decoration-warning="movement_type == 'adjustment'">
                    <field name="date"/>
                    <field name="product_type"/>
                    <field name="product_name"/>
                    <field name="movement_type" widget="badge"/>
                    <field name="quantity"/>
                    <field name="reference"/>
                    <field name="reason"/>
                    <field name="user_id"/>
                    <field name="branch_id"/>
                </list>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="action_inventory_frame" model="ir.actions.act_window">
            <field name="name">Frames</field>
            <field name="res_model">eyekei.inventory.frame</field>
            <field name="view_mode">list,form</field>
        </record>
        
        <record id="action_inventory_lens" model="ir.actions.act_window">
            <field name="name">Lenses</field>
            <field name="res_model">eyekei.inventory.lens</field>
            <field name="view_mode">list,form</field>
        </record>
        
        <record id="action_stock_movement" model="ir.actions.act_window">
            <field name="name">Stock Movements</field>
            <field name="res_model">eyekei.stock.movement</field>
            <field name="view_mode">list</field>
        </record>
        
        <menuitem id="menu_inventory_root" name="Inventory" parent="menu_eyekei_root" sequence="5"/>
        <menuitem id="menu_inventory_frames" name="Frames" parent="menu_inventory_root" action="action_inventory_frame" sequence="1"/>
        <menuitem id="menu_inventory_lenses" name="Lenses" parent="menu_inventory_root" action="action_inventory_lens" sequence="2"/>
        <menuitem id="menu_inventory_movements" name="Stock Movements" parent="menu_inventory_root" action="action_stock_movement" sequence="3"/>
    </data>
</odoo>