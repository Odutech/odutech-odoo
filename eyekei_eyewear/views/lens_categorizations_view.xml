<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_eyekei_lens_type_list" model="ir.ui.view">
        <field name="name">eyekei.lens.type.categorization.list</field>
        <field name="model">eyekei.lens.type.categorization</field>
        <field name="arch" type="xml">
            <list string="Lens Type Categorization">
                <field name="name"/>
                <field name="lens_categorization"/>
            </list>
        </field>
    </record>

    <record id="view_eyekei_lens_type_form" model="ir.ui.view">
        <field name="name">eyekei.lens.type.categorization.form</field>
        <field name="model">eyekei.lens.type.categorization</field>
        <field name="arch" type="xml">
            <form string="Lens Type Categorization">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g. Anti-Reflective"/>
                            <field name="code" placeholder="e.g. 202390859485" required="lens_categorization =='frame_brand'" invisible="lens_categorization !='frame_brand'"/>
                        </group>
                        <group>
                            <field name="lens_categorization"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_eyekei_lens_type" model="ir.actions.act_window">
        <field name="name">Lens Type Categorization</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">eyekei.lens.type.categorization</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first lens category!
            </p>
        </field>
    </record>

    <menuitem id="menu_eyekei_lens_type_categorization"
              name="Lens Categorization"
              parent="eyekei_eyewear.menu_lab_root"
              action="action_eyekei_lens_type"
              sequence="10"/>
</odoo>