        <!-- Action for Wizard -->
        <record id="action_stock_update_wizard" model="ir.actions.act_window">
            <field name="name">Quick Stock Update</field>
            <field name="res_model">eyekei.stock.update.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>
        
        <!-- Action for Audit Log -->
        <record id="action_stock_audit_log" model="ir.actions.act_window">
            <field name="name">Stock Adjustment History</field>
            <field name="res_model">eyekei.stock.audit</field>
            <field name="view_mode">list,form</field>
        </record>
