<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Stock Update Wizard Form -->
        <record id="view_stock_update_wizard_form" model="ir.ui.view">
            <field name="name">eyekei.stock.update.wizard.form</field>
            <field name="model">eyekei.stock.update.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="alert alert-info" role="alert">
                            <i class="fa fa-info-circle" title="Info"/> 
                            Use this wizard to quickly adjust optical product stock levels. 
                            All adjustments are logged for audit purposes.
                        </div>
                        
                        <group>
                            <field name="product_id" 
                                   options="{'no_create': True, 'no_edit': True}"
                                   widget="many2one_avatar_product"/>
                            <field name="location_id" 
                                   options="{'no_create': True}"
                                   groups="stock.group_stock_multi_locations"/>
                        </group>
                        
                        <div class="o_horizontal_separator">Stock Information</div>
                        <div class="row">
                            <div class="col-6">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h4 class="text-muted">Current Quantity</h4>
                                        <h2><field name="current_quantity" readonly="1"/></h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="card bg-primary text-white">
                                    <div class="card-body text-center">
                                        <h4>New Quantity</h4>
                                        <h2><field name="new_quantity"/></h2>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <group class="mt-4">
                            <field name="reason" 
                                   placeholder="Enter reason for stock adjustment (required for audit trail)"/>
                        </group>
                        
                        <div class="alert alert-warning mt-4" role="alert" invisible="new_quantity &gt;= current_quantity">
                            <i class="fa fa-exclamation-triangle" title="Warning"/>
                            <strong>Stock Reduction:</strong> This will reduce inventory. 
                            Manager approval may be required.
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_update_stock" 
                                string="Update Stock" 
                                type="object" 
                                class="btn btn-primary"
                                confirm="Are you sure you want to update the stock? This action cannot be undone."/>
                        <button string="Cancel" 
                                class="btn btn-secondary" 
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <!-- Stock Audit Log list View -->
        <record id="view_stock_audit_list" model="ir.ui.view">
            <field name="name">eyekei.stock.audit.list</field>
            <field name="model">eyekei.stock.audit</field>
            <field name="arch" type="xml">
                <list decoration-danger="difference &lt; 0" 
                      decoration-success="difference &gt; 0">
                    <field name="create_date"/>
                    <field name="product_id"/>
                    <field name="inventory_id"/>
                    <field name="location_id"/>
                    <field name="previous_quantity"/>
                    <field name="new_quantity"/>
                    <field name="difference"/>
                    <field name="reason"/>
                    <field name="user_id"/>
                </list>
            </field>
        </record>
        
