<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Submission Batch PDF Report -->
        <template id="submission_batch_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <!-- Company Letterhead -->
                            <div class="row mb-4">
                                <div class="col-12 text-center">
                                    <h2 t-field="company.name"/>
                                    <p t-field="company.partner_id.street"/>
                                    <p>Phone: <span t-field="company.phone"/> | Email: <span t-field="company.email"/></p>
                                </div>
                            </div>
                            
                            <hr/>
                            
                            <!-- Submission Header -->
                            <div class="row mb-4">
                                <div class="col-6">
                                    <h3>INSURANCE CLAIM SUBMISSION</h3>
                                    <p><strong>Serial Number:</strong> <span t-field="doc.serial_number"/></p>
                                    <p><strong>Date:</strong> <span t-field="doc.submission_date"/></p>
                                </div>
                                <div class="col-6 text-end">
                                    <p><strong>Insurance Company:</strong> <span t-field="doc.insurance_company"/></p>
                                    <p><strong>Total Claims:</strong> <span t-field="doc.claim_count"/></p>
                                    <p><strong>Total Amount:</strong> <span t-field="doc.total_amount"/></p>
                                </div>
                            </div>
                            
                            <!-- Claims Table -->
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Patient Name</th>
                                        <th>Member No</th>
                                        <th>Invoice No</th>
                                        <th>eTIMS No</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.claim_ids" t-as="claim" t-key="claim.id">
                                        <td><span t-esc="claim_index + 1"/></td>
                                        <td><span t-field="claim.patient_id.name"/></td>
                                        <td><span t-field="claim.member_number"/></td>
                                        <td><span t-field="claim.invoice_number"/></td>
                                        <td><span t-field="claim.etims_number"/></td>
                                        <td class="text-end"><span t-field="claim.billed_amount"/></td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="5" class="text-end"><strong>Total:</strong></td>
                                        <td class="text-end"><strong t-field="doc.total_amount"/></td>
                                    </tr>
                                </tfoot>
                            </table>
                            
                            <!-- Stamp Area -->
                            <div t-if="doc.company_stamp_area" class="mt-5 pt-5">
                                <div class="row">
                                    <div class="col-6">
                                        <p>Prepared By: _______________________</p>
                                        <p>Date: _______________________</p>
                                    </div>
                                    <div class="col-6 text-end">
                                        <div style="border: 2px solid #000; width: 150px; height: 150px; display: inline-block;">
                                            <p class="text-center mt-5">Company Stamp</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
        
        <record id="action_report_submission_batch" model="ir.actions.report">
            <field name="name">Submission Batch Report</field>
            <field name="model">eyekei.submission.batch</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">eyekei_eyewear.submission_batch_report</field>
            <field name="report_file">eyekei_eyewear.submission_batch_report</field>
            <field name="print_report_name">'Submission - %s' % (object.serial_number)</field>
            <field name="binding_model_id" ref="model_eyekei_submission_batch"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>