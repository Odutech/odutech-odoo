<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Privilege for EYEKEI groups -->
<!--        <record model="res.groups.privilege" id="res_groups_privilege_eyekei">-->
<!--            <field name="name">EYEKEI Optical</field>-->
<!--            <field name="sequence">10</field>-->
<!--        </record>-->

        <!-- Reception Group -->
        <record id="group_eyekei_reception" model="res.groups">
            <field name="name">Reception</field>
<!--            <field name="privilege_id" ref="res_groups_privilege_eyekei"/>-->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Optometrist Group -->
        <record id="group_eyekei_optometrist" model="res.groups">
            <field name="name">Optometrist</field>
<!--            <field name="privilege_id" ref="res_groups_privilege_eyekei"/>-->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Lab Technician Group -->
        <record id="group_eyekei_lab_tech" model="res.groups">
            <field name="name">Lab Technician</field>
<!--            <field name="privilege_id" ref="res_groups_privilege_eyekei"/>-->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Lab Manager Group -->
        <record id="group_eyekei_lab_manager" model="res.groups">
            <field name="name">Lab Manager</field>
<!--            <field name="privilege_id" ref="res_groups_privilege_eyekei"/>-->
            <field name="implied_ids" eval="[(4, ref('group_eyekei_lab_tech'))]"/>
        </record>

        <!-- Manager Group -->
        <record id="group_eyekei_manager" model="res.groups">
            <field name="name">Manager</field>
<!--            <field name="privilege_id" ref="res_groups_privilege_eyekei"/>-->
            <field name="implied_ids" eval="[
                (4, ref('group_eyekei_reception')),
                (4, ref('group_eyekei_optometrist')),
                (4, ref('group_eyekei_lab_manager'))
            ]"/>
        </record>

        <!-- Administrator Group -->
        <record id="group_eyekei_admin" model="res.groups">
            <field name="name">Administrator</field>
<!--            <field name="privilege_id" ref="res_groups_privilege_eyekei"/>-->
            <field name="implied_ids" eval="[(4, ref('group_eyekei_manager')), (4, ref('base.group_system'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>