<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_password_reset" model="mail.template">
        <field name="name">User Authentication: Password Reset Request</field>
        <field name="model_id" ref="odutech_expense_manager.model_expense_user"/>
        <field name="subject">Reset your account password</field>
        <field name="email_from">{{ object.company_id.email or 'noreply@yourdomain.com' }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>

        <field name="body_html" type="html">
            <div style="background-color: #f4f6f8; padding: 40px 20px; font-family: 'Segoe UI', Arial, sans-serif; color: #495057; line-height: 1.6;">
                <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; background-color: #ffffff; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">

                    <!-- 1. Header Banner -->
                    <tr>
                        <td align="center" style="background-color: #1a90ad; padding: 35px 20px;">
                            <img t-attf-src="/logo.png?company={{ object.company_id.id }}"
                                 alt="Company Logo"
                                 style="max-height: 55px; display: block; border: none;"/>
                        </td>
                    </tr>

                    <!-- 2. Content Body -->
                    <tr>
                        <td style="padding: 40px 35px 30px 35px;">
                            <h2 style="margin-top: 0; color: #212529; font-size: 24px; font-weight: 600;">
                                Hello, <t t-out="object.name or object.email"/>
                            </h2>
                            <p style="color: #495057; font-size: 16px; margin-bottom: 20px;">
                                We received a request to reset the password for your account. No changes have been made to your profile yet.
                            </p>
                            <p style="color: #495057; font-size: 16px; margin-bottom: 30px;">
                                You can safely reset your password by clicking the secure button below:
                            </p>
                        </td>
                    </tr>

                    <!-- 3. Call To Action (CTA) Link -->
                    <tr>
                        <td align="center" style="padding: 0 35px 30px 35px;">
                            <!-- Dynamic route built using your custom helper logic or system variables safely -->
                            <a t-attf-href="{{ object.company_id.expense_link or '/api/auth/reset-password' }}?token={{ object.reset_password_token }}"
                               style="background-color: #1a90ad; color: #ffffff; padding: 14px 32px; text-decoration: none; font-size: 15px; font-weight: bold; border-radius: 5px; display: inline-block; box-shadow: 0 4px 10px rgba(26, 144, 173, 0.25);">
                                Reset My Password
                            </a>
                        </td>
                    </tr>

                    <!-- 4. Security Warning Thresholds -->
                    <tr>
                        <td style="padding: 0 35px 40px 35px;">
                            <p style="color: #777777; font-size: 14px; background-color: #fff9db; padding: 12px 15px; border-left: 4px solid #fcc419; border-radius: 4px; margin-bottom: 25px;">
                                <strong>Note:</strong> This recovery link is only valid for <strong>20 minutes</strong>. After expiration, you will need to submit a brand new request.
                            </p>
                            <hr style="border: 0; border-top: 1px solid #e9ecef; margin: 25px 0;"/>
                            <p style="color: #868e96; font-size: 13px; margin: 0;">
                                If you didn't initiate this action, please disregard this notification completely. Your credentials remain safe and protected.
                            </p>
                        </td>
                    </tr>

                    <!-- 5. Footer Layout -->
                    <tr>
                        <td style="background-color: #f8f9fa; padding: 35px 30px; text-align: center; border-top: 1px solid #e9ecef;">
                            <p style="margin: 0 0 10px 0; font-size: 15px; color: #343a40; font-weight: 600;">
                                <t t-out="object.company_id.name"/>
                            </p>

                            <!-- Navigation Links Context Hook -->
                            <p style="margin: 0; font-size: 13px;">
                                <a t-att-href="object.company_id.website or '#'" style="color: #1a90ad; text-decoration: none; font-weight: 500; margin: 0 12px;">Our Website</a> |
                                <a href="https://yourplatform.com/support" style="color: #1a90ad; text-decoration: none; font-weight: 500; margin: 0 12px;">Help Desk</a> |
                                <a href="https://yourplatform.com/privacy" style="color: #1a90ad; text-decoration: none; font-weight: 500; margin: 0 12px;">Privacy Guard</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </div>
        </field>
    </record>
</odoo>