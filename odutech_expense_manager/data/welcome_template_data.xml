<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_welcome_onboarding" model="mail.template">
        <field name="name">User Onboarding: Welcome &amp; Benefits</field>
        <field name="model_id" ref="odutech_expense_manager.model_expense_user"/>
        <field name="subject">Welcome to your smarter financial journey!</field>
        <field name="email_from">{{ object.company_id.email or 'noreply@yourdomain.com' }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>

        <field name="body_html" type="html">
            <div style="background-color: #f4f6f8; padding: 40px 20px; font-family: 'Segoe UI', Arial, sans-serif; color: #495057; line-height: 1.6;">
                <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; background-color: #ffffff; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">

                    <!-- 1. Header & Logo Banner -->
                    <tr>
                        <td align="center" style="background-color: #1a90ad; padding: 35px 20px;">
                            <img t-attf-src="/logo.png?company={{ object.company_id.id }}"
                                 alt="Company Logo"
                                 style="max-height: 55px; display: block; border: none;"/>
                        </td>
                    </tr>

                    <!-- 2. Hero Welcome Message -->
                    <tr>
                        <td style="padding: 40px 35px 20px 35px;">
                            <h2 style="margin-top: 0; color: #212529; font-size: 26px; font-weight: 700; text-align: center;">
                                Welcome Aboard, <t t-out="object.name or object.email"/>!
                            </h2>
                            <p style="color: #6c757d; font-size: 16px; text-align: center; margin-bottom: 30px;">
                                Thank you for joining us. You've just taken your first critical step toward absolute financial clarity and effortless budgeting.
                            </p>
                            <hr style="border: 0; border-top: 1px solid #e9ecef; margin: 20px 0;"/>
                        </td>
                    </tr>

                    <!-- 3. Dynamic Platform Social Proof Statistics -->
                    <tr>
                        <td style="padding: 0 35px 20px 35px;">
                            <div style="background: linear-gradient(135deg, #1a90ad 0%, #0f5c70 100%); padding: 25px; text-align: center; border-radius: 8px; color: #ffffff;">
                                <span style="display: block; font-size: 13px; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.85; font-weight: 600; margin-bottom: 5px;">
                                    Growing Together
                                </span>
                                <span style="font-size: 36px; font-weight: 800; display: block; margin-bottom: 5px;">
                                    <t t-out="object.get_total_platform_users()"/>+
                                </span>
                                <p style="margin: 0; font-size: 14px; opacity: 0.9;">
                                    Active members are currently optimizing their financial health on our platform right now!
                                </p>
                            </div>
                        </td>
                    </tr>

                    <!-- 4. Key Benefits Core Matrix -->
                    <tr>
                        <td style="padding: 20px 35px 30px 35px;">
                            <h3 style="color: #212529; font-size: 18px; font-weight: 600; margin-bottom: 20px;">
                                Why Tracking Matters:
                            </h3>

                            <!-- Benefit 1 -->
                            <div style="margin-bottom: 20px; display: flex; align-items: flex-start;">
                                <div style="background-color: #e8f4f7; color: #1a90ad; font-weight: bold; padding: 8px 14px; border-radius: 50%; margin-right: 15px; font-size: 16px;">1</div>
                                <div>
                                    <h4 style="margin: 0 0 4px 0; color: #343a40; font-size: 15px; font-weight: 600;">Plug Hidden Money Leaks</h4>
                                    <p style="margin: 0; font-size: 14px; color: #6c757d;">Categorize expenses automatically to uncover sub-conscious patterns and unnecessary subscriptions.</p>
                                </div>
                            </div>

                            <!-- Benefit 2 -->
                            <div style="margin-bottom: 20px; display: flex; align-items: flex-start;">
                                <div style="background-color: #e8f4f7; color: #1a90ad; font-weight: bold; padding: 8px 14px; border-radius: 50%; margin-right: 15px; font-size: 16px;">2</div>
                                <div>
                                    <h4 style="margin: 0 0 4px 0; color: #343a40; font-size: 15px; font-weight: 600;">Real-Time Financial Intelligence</h4>
                                    <p style="margin: 0; font-size: 14px; color: #6c757d;">Access visual breakdowns of cashflows instantly, anytime, from any connected interface.</p>
                                </div>
                            </div>

                            <!-- Benefit 3 -->
                            <div style="margin-bottom: 25px; display: flex; align-items: flex-start;">
                                <div style="background-color: #e8f4f7; color: #1a90ad; font-weight: bold; padding: 8px 14px; border-radius: 50%; margin-right: 15px; font-size: 16px;">3</div>
                                <div>
                                    <h4 style="margin: 0 0 4px 0; color: #343a40; font-size: 15px; font-weight: 600;">Achieve Your Savings Milestones</h4>
                                    <p style="margin: 0; font-size: 14px; color: #6c757d;">Set precise monthly allocations and stay accountable with proactive usage notifications.</p>
                                </div>
                            </div>
                        </td>
                    </tr>

                    <!-- 5. Call To Action (CTA) Link -->
                    <tr>
                        <td align="center" style="padding: 0 35px 40px 35px;">
                            <a t-att-href="object.company_id.expense_link or '/web/login'" style="background-color: #1a90ad; color: #ffffff; padding: 14px 32px; text-decoration: none; font-size: 15px; font-weight: bold; border-radius: 5px; display: inline-block; box-shadow: 0 4px 10px rgba(26, 144, 173, 0.25);">
                                Launch Your Dashboard
                            </a>
                        </td>
                    </tr>

                    <!-- 6. Company Signature & Global Links Footer -->
                    <tr>
                        <td style="background-color: #f8f9fa; padding: 35px 30px; text-align: center; border-top: 1px solid #e9ecef;">
                            <p style="margin: 0 0 10px 0; font-size: 15px; color: #343a40; font-weight: 600;">
                                <t t-out="object.company_id.name"/>
                            </p>

                            <!-- Navigation Links Context Hook -->
                            <p style="margin: 0; font-size: 13px;">
                                <a t-att-href="object.company_id.website or '#'" style="color: #1a90ad; text-decoration: none; font-weight: 500; margin: 0 12px;">Our Website</a> |
                                <a href="https://yourplatform.com/dashboard" style="color: #1a90ad; text-decoration: none; font-weight: 500; margin: 0 12px;">App Portal</a> |
                                <a href="https://yourplatform.com/privacy" style="color: #1a90ad; text-decoration: none; font-weight: 500; margin: 0 12px;">Privacy Guard Policy</a>
                            </p>

                            <p style="margin: 20px 0 0 0; font-size: 11px; color: #adb5bd;">
                                This welcome notification was automatically triggered for account registration. Please do not reply directly.
                            </p>
                        </td>
                    </tr>
                </table>
            </div>
        </field>
    </record>
</odoo>